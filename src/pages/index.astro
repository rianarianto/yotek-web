---
/**
 * Home Page — PT. Yogura Tekindo
 * Stage 2: Hero Section (Light & Professional)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CEOVideo from '../components/CEOVideo.astro';
import AboutBrief from '../components/AboutBrief.astro';
import Achievement from '../components/Achievement.astro';
import BusinessUnits from '../components/BusinessUnits.astro';
import GlobalImpact from '../components/GlobalImpact.astro';
import CTA from '../components/CTA.astro';
import { SITE, STATS } from '../constants/site';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<BaseLayout>
  <!-- HERO SECTION -->
  <Hero />

  <!-- CEO VISION SECTION -->
  <CEOVideo />

  <!-- ABOUT BRIEF SECTION -->
  <AboutBrief />

  <!-- ACHIEVEMENT SECTION -->
  <Achievement />

  <!-- BUSINESS UNITS SECTION -->
  <BusinessUnits />

  <!-- GLOBAL IMPACT SECTION -->
  <GlobalImpact />

  <!-- CTA SECTION -->
  <CTA />

</BaseLayout>
