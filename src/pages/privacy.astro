---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../constants/site';
---

<BaseLayout title="Kebijakan Privasi | Yotek" description="Kebijakan Privasi PT. Yogura Tekindo.">
  <div class="bg-white min-h-screen">
    
    <!-- Hero Section — Left aligned title in a container with background image -->
    <header class="relative !py-32 lg:!py-48 !px-6 lg:!px-16 w-full flex items-center overflow-hidden">
      <!-- Background Asset -->
      <div class="absolute inset-0 w-full h-full z-0 pointer-events-none">
        <img 
          src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&q=80&w=2000" 
          alt="Privacy Background" 
          class="w-full h-full object-cover opacity-100"
        />
        <div class="absolute inset-0 bg-black/90"></div>
      </div>

      <div class="relative z-10 w-full !mx-auto reveal">
        <h1 class="!text-[32px] md:!text-[48px] lg:!text-[48px] font-700 !text-white !leading-tight !mb-0"
          style="text-transform: none !important;">
          Kebijakan Privasi
        </h1>
      </div>
    </header>

    <!-- Content Container — Focused in center, but text left-aligned with accordions -->
    <div class="!py-24 lg:!py-32 !px-6 lg:!px-16 flex justify-center">
      <div class="w-full !max-w-[800px] flex flex-col reveal text-left">
        
        <p class="text-gray-400 text-[13px] font-600 !mb-16">Terakhir diperbarui: 24 April 2026</p>

        <div class="space-y-0" id="privacy-accordion">
          
          {[
            { id: '01', q: 'Informasi yang Kami Kumpulkan', a: 'Kami mengumpulkan informasi yang Anda berikan langsung kepada kami saat menggunakan formulir kontak atau melamar posisi pekerjaan. Ini mencakup nama, alamat email, nomor telepon, serta dokumen CV atau resume yang Anda unggah secara sadar di portal karir Yotek Group.' },
            { id: '02', q: 'Penggunaan Informasi', a: 'Data Anda hanya digunakan untuk tujuan operasional internal: menanggapi pertanyaan bisnis, memproses aplikasi rekrutmen, serta meningkatkan pengalaman navigasi Anda di ekosistem platform kami. Kami tidak mendistribusikan data Anda kepada pihak luar untuk kepentingan komersial.' },
            { id: '03', q: 'Protokol Keamanan Data', a: 'Keamanan informasi Anda adalah prioritas utama. Yotek Group menerapkan standar keamanan dan enkripsi digital untuk melindungi data dari akses, perubahan, atau pengungkapan yang tidak sah oleh pihak yang tidak memiliki otorisasi.' },
            { id: '04', q: 'Berbagi Informasi', a: 'Kami tidak menjual atau menyewakan informasi pribadi Anda. Informasi hanya akan diakses oleh tim internal yang relevan (HR atau Sales) untuk keperluan tindak lanjut dari permintaan yang telah Anda ajukan melalui website ini.' },
            { id: '05', q: 'Hak Privasi Anda', a: 'Anda berhak untuk menanyakan, memperbarui, atau meminta penghapusan data pribadi Anda dari database kami kapan saja. Untuk permohonan tersebut, silakan hubungi pusat bantuan kami melalui detail kontak yang tersedia di bawah ini.' }
          ].map((item) => (
            <div class="legal-item !border-b !border-gray-100 last:border-0 transition-colors duration-500">
              <button class="legal-trigger w-full !py-8 flex items-center justify-between text-left focus:outline-none group">
                <h2 class="text-[18px] md:text-[22px] lg:!text-[26px] font-700 text-black flex items-center !gap-6 transition-colors duration-500 group-hover:text-[var(--color-gold)]">
                  {item.q}
                </h2>
                <span class="legal-icon opacity-30 group-hover:opacity-100 transition-opacity">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </span>
              </button>
              <div class="legal-content overflow-hidden" style="height: 0;">
                <div class="!pb-10 !pl-14">
                  <p class="text-gray-500 text-[16px] lg:text-[17px] !leading-[1.8] !max-w-2xl font-500">
                    {item.a}
                  </p>
                </div>
              </div>
            </div>
          ))}

        </div>

        <footer class="!mt-24 !pt-16 border-t border-gray-100">
          <p class="text-[11px] font-800 uppercase tracking-widest text-[#AAA] !mb-4">Data Privacy Rights</p>
          <a href={`mailto:${SITE.email}`} class="text-[18px] font-700 text-black hover:text-[var(--color-gold)] transition-colors underline underline-offset-8 decoration-gray-200 hover:decoration-[var(--color-gold)]">
             {SITE.email}
          </a>
        </footer>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { animateReveal } from '../scripts/animations';

  function initLegalPage() {
    const container = document.querySelector('.space-y-0') as HTMLElement;
    if (!container || container.dataset.initialized) return;

    animateReveal('.reveal', { stagger: 0.15 });

    // Single delegated listener
    const handleToggle = (e: Event) => {
      const target = e.target as HTMLElement;
      const trigger = target.closest('.legal-trigger');
      if (!trigger) return;

      e.preventDefault();
      e.stopPropagation();

      const item = trigger.closest('.legal-item');
      if (!item) return;

      const content = item.querySelector('.legal-content') as HTMLElement;
      const icon = item.querySelector('.legal-icon svg');
      const isActive = item.classList.contains('active');

      // Close others first
      if (!isActive) {
        document.querySelectorAll('.legal-item.active').forEach(other => {
          if (other !== item) {
            other.classList.remove('active');
            gsap.to(other.querySelector('.legal-content'), { height: 0, duration: 0.4, ease: "power2.inOut", overwrite: true });
            gsap.to(other.querySelector('.legal-icon svg'), { rotate: 0, duration: 0.4, ease: "power2.inOut", overwrite: true });
          }
        });
      }

      // Toggle current
      if (isActive) {
        item.classList.remove('active');
        gsap.to(content, { height: 0, duration: 0.5, ease: "power2.inOut", overwrite: true, force3D: true });
        gsap.to(icon, { rotate: 0, duration: 0.5, ease: "power2.inOut", overwrite: true });
      } else {
        item.classList.add('active');
        gsap.to(content, { height: "auto", duration: 0.6, ease: "power2.out", overwrite: true, force3D: true });
        gsap.to(icon, { rotate: 180, duration: 0.6, ease: "power2.out", overwrite: true });
      }
    };

    container.addEventListener('click', handleToggle);
    container.dataset.initialized = "true";
  }

  document.addEventListener('astro:page-load', initLegalPage);
</script>
