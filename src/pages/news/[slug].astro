---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
export async function getStaticPaths() {
  const news = await getCollection('news');
  return news.map((post) => ({ params: { slug: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="section bg-[var(--color-abyss)]">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="max-w-3xl mx-auto">
        <a href="/news" class="inline-flex items-center gap-2 text-xs text-[var(--color-steel)] hover:text-[var(--color-gold)] transition-colors duration-300 mb-8 uppercase tracking-wider">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" /></svg>
          Kembali
        </a>
        <header class="mb-10">
          <time class="text-[10px] text-[var(--color-gold)] font-display font-600 uppercase tracking-[0.15em]">
            {new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h1 class="text-3xl lg:text-5xl font-display font-800 text-white mt-4 mb-6 uppercase tracking-tight leading-[0.95]">{post.data.title}</h1>
          <p class="text-base text-[var(--color-ash)] leading-relaxed">{post.data.description}</p>
        </header>
        {post.data.image && (
          <div class="overflow-hidden mb-10 aspect-video bg-[var(--color-charcoal)]">
            <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" loading="eager" />
          </div>
        )}
        <div class="prose-dark"><Content /></div>
      </div>
    </div>
  </article>
</BaseLayout>
