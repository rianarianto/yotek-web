---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<BaseLayout title="News & Updates | Yotek" description="Keep up with the latest news, press releases, and updates from PT. Yogura Tekindo.">
  
  <!-- PREMIUM NEWS HERO -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 bg-[#F8F8F6] overflow-hidden">
    <div class="container mx-auto px-6 lg:px-16 relative z-10">
      <div class="max-w-4xl">
        <p class="reveal text-[13px] font-800 uppercase tracking-widest text-gray-400 mb-6">
          News & Updates
        </p>
        <h1 class="reveal text-black font-700 leading-tight tracking-[-0.03em] mb-8"
          style="font-size: clamp(2.5rem, 6vw, 80px); text-transform: none !important;">
          Torehan Jejak & <br />
          <span class="text-gray-400">Inovasi Terbaru Kami.</span>
        </h1>
        <div class="reveal w-20 h-1 bg-black/10"></div>
      </div>
    </div>

    <!-- Decorative Element -->
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-[0.03] pointer-events-none translate-x-1/4">
       <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
         <path d="M0,250 C100,100 400,100 500,250" stroke="black" stroke-width="1" fill="none" />
       </svg>
    </div>
  </section>

  <!-- NEWS GRID -->
  <section class="pb-32 bg-[#F8F8F6]">
    <div class="container mx-auto px-6 lg:px-16">
      {sortedNews.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16 lg:gap-y-24">
          {sortedNews.map((post) => (
            <a href={`/news/${post.id}`} class="news-item group block">
              <div class="relative aspect-[4/3] mb-8 overflow-hidden bg-gray-100 grayscale hover:grayscale-0 transition-all duration-700 ease-in-out">
                {post.data.image ? (
                  <img 
                    src={post.data.image} 
                    alt={post.data.title} 
                    class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000" 
                    loading="lazy" 
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-gray-300 bg-gray-50">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500"></div>
              </div>
              
              <div class="space-y-4">
                <div class="flex items-center gap-4 text-[11px] font-800 uppercase tracking-widest text-black/40">
                  <span>Press Release</span>
                  <span class="w-8 h-[1px] bg-black/10"></span>
                  <time datetime={post.data.pubDate.toString()}>
                    {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
                
                <h3 class="text-2xl lg:text-[26px] font-700 text-black leading-tight tracking-tight group-hover:text-gray-600 transition-colors duration-300">
                  {post.data.title}
                </h3>
                
                <p class="text-gray-500 text-[15px] leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>
                
                <div class="pt-2">
                  <div class="inline-flex items-center gap-2 text-[12px] font-800 uppercase tracking-wider text-black group-hover:gap-4 transition-all duration-300">
                    Read More
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-40">
          <p class="text-gray-400 font-600">Belum ada berita yang diterbitkan.</p>
        </div>
      )}
    </div>
  </section>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { animateReveal } from '../../scripts/animations';

    gsap.registerPlugin(ScrollTrigger);

    function initNewsPage() {
      // Reveal items on load
      document.querySelectorAll('.reveal').forEach((el) => {
        animateReveal(el as HTMLElement, { y: 30, duration: 1.2 });
      });

      // Reveal grid items on scroll
      gsap.to(".news-item", {
        scrollTrigger: {
          trigger: ".news-item",
          start: "top 85%",
        },
        y: 0,
        opacity: 1,
        duration: 1.2,
        stagger: 0.15,
        ease: "power3.out"
      });
    }

    document.addEventListener('astro:page-load', initNewsPage);
  </script>

  <style>
    .news-item {
      opacity: 0;
      transform: translateY(30px);
    }
  </style>
</BaseLayout>
