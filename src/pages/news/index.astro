---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<BaseLayout title="Berita" description="Berita terbaru seputar PT. Yogura Tekindo.">
  <section class="py-20 lg:py-28 bg-[var(--color-abyss)]">
    <div class="container mx-auto px-6 lg:px-12">
      <p class="kicker mb-4">Berita</p>
      <h1 class="text-white">Berita Terbaru</h1>
    </div>
  </section>

  <section class="pb-24 bg-[var(--color-abyss)]">
    <div class="container mx-auto px-6 lg:px-12">
      {sortedNews.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-1">
          {sortedNews.map((post) => (
            <a href={`/news/${post.id}`} class="news-card group block card-dark">
              <div class="relative aspect-[16/10] overflow-hidden bg-[var(--color-dark-surface)]">
                {post.data.image ? (
                  <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-700 ease-[var(--ease-out-expo)] group-hover:scale-105 opacity-80 group-hover:opacity-100" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[var(--color-dark-surface)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" /></svg>
                  </div>
                )}
              </div>
              <div class="p-6">
                <time class="text-[10px] text-[var(--color-steel)] uppercase tracking-[0.15em]">
                  {new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h2 class="text-base font-display font-600 text-white mt-3 mb-2 uppercase tracking-tight leading-tight transition-colors duration-300 group-hover:text-[var(--color-gold)] line-clamp-2">{post.data.title}</h2>
                <p class="text-sm text-[var(--color-ash)] line-clamp-2">{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-[var(--color-ash)]">Belum ada berita.</p>
        </div>
      )}
    </div>
  </section>

  <script>
    import { staggerChildren } from '../../scripts/animations';
    document.addEventListener('astro:page-load', () => { staggerChildren('.grid', '.news-card', { stagger: 0.1, y: 20 }); });
  </script>
</BaseLayout>
