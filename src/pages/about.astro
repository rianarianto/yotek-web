---
/**
* About Page — Light Theme with 3D Building Hero
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CEO } from '../constants/site';
import { Image } from 'astro:assets';
import buildingImage from '../assets/images/building.avif';
import riauImg from '../assets/images/riau.avif';
import footerBgImg from '../assets/images/footer-bg.avif';
import tempBusinessImg from '../assets/images/temp_business_unit.jpg';
import ctaBuildingImg from '../assets/images/cta-building.avif';
---

<BaseLayout title="About Us | Yotek" description="Pelajari lebih lanjut tentang PT. Yogura Tekindo, visi misi kami.">

  <!-- HERO SECTION -->
  <section
    class="relative w-full h-[100svh] min-h-[600px] md:h-[120vh] md:min-h-[800px] bg-[#FCFCFC] overflow-hidden flex items-center justify-center">

    <!-- Massive Headline (Background layer) -->
    <div
      class="absolute inset-x-0 w-full flex justify-center top-[25%] md:top-[24%] -translate-y-1/2 z-0 pointer-events-none px-4">
      <h1
        class="!text-[12vw] md:!text-[12vw] lg:!text-[6vw] max-w-[100vw] font-700 tracking-tighter leading-none text-[#222222] opacity-0 transform translate-y-10 text-center"
        id="hero-title">
        All About Yotek
      </h1>
    </div>

    <!-- 3D Building (Foreground layer) -->
    <div
      class="relative z-10 w-[120%] sm:w-[90%] md:w-[70%] lg:w-[36%] max-w-[1000px] mx-auto mt-20 md:mt-32 opacity-0 transform scale-95"
      id="hero-building">
      <Image src={buildingImage} alt="Yotek Headquarters" format="avif" quality={100}
        class="w-full h-auto object-contain drop-shadow-2xl" loading="eager" />
    </div>

    <!-- Left Floating Text -->
    <div
      class="absolute left-[4%] md:left-[10%] lg:left-[15%] top-[58%] md:top-[50%] z-20 opacity-0 transform -translate-x-8"
      id="hero-text-left">
      <p class="text-[14px] md:text-[24px] lg:text-[32px] font-600 text-[#333333] tracking-tight">
        Integritas &amp; Kinerja.
      </p>
    </div>

    <!-- Right Floating Text -->
    <div
      class="absolute right-[4%] md:right-[10%] lg:right-[15%] top-[67%] md:top-[60%] z-20 opacity-0 transform translate-x-8"
      id="hero-text-right">
      <p class="text-[14px] md:text-[24px] lg:text-[32px] font-600 text-[#333333] tracking-tight">
        Solusi Inovatif.
      </p>
    </div>

  </section>

  <!-- Culture / Journey Section (Sticky Left, Scroll Right) -->
  <section class="relative !py-24 lg:!py-60 bg-[#FCFCFC] w-full border-y border-gray-100 flex justify-center">
    <div class="w-full !px-6 lg:!px-16 max-w-[1500px] mx-auto">
      <div class="flex flex-col lg:flex-row justify-between gap-16 lg:gap-24 relative">

        <!-- Left Group: Sticky Text -->
        <div class="w-full lg:w-[40%] relative">
          <div class="lg:sticky lg:top-1/2 lg:-translate-y-1/2 lg:!mt-36" id="culture-sticky-text">
            <h2 class="culture-txt opacity-0 font-700 tracking-tight leading-[1.05] !mb-6 text-[#111]"
              style="font-size: clamp(3rem, 5vw, 64px); text-transform: none !important;">
              Sinergi &amp; Kolaborasi
            </h2>
            <p
              class="culture-txt opacity-0 text-[16px] lg:text-[17px] font-400 text-gray-500 leading-relaxed lg:max-w-[420px]">
              Kami percaya bahwa inovasi lahir dari ruang kerja yang dinamis. Yotek memastikan setiap tim dapat
              terkoneksi secara harmonis untuk merancang solusi terintegrasi yang berdampak nyata.
            </p>
          </div>
        </div>

        <!-- Right Group: Scrolling Images (3 overlapping on desktop, stacked on mobile) -->
        <div class="w-full lg:w-[55%] flex flex-col gap-0 lg:!gap-0 items-center" id="culture-images">

          <div
            class="culture-img-card opacity-0 translate-y-10 w-full overflow-hidden shadow-md aspect-[4/3] bg-gray-100 relative group">
            <Image src={import('../assets/images/footer-bg.avif')} alt="Yotek Collaboration"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" quality={90} />
          </div>

          <div
            class="culture-img-card opacity-0 translate-y-10 w-[85%] md:w-[80%] lg:w-[75%] ml-auto overflow-hidden shadow-2xl aspect-[3/4] bg-gray-100 relative group z-20 !-mt-24 lg:!mr-8">
            <Image src={import('../assets/images/temp_business_unit.jpg')} alt="Yotek Workspace"
              class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0"
              quality={90} />
          </div>

          <div
            class="culture-img-card opacity-0 translate-y-10 w-full overflow-hidden shadow-md aspect-[16/9] bg-gray-100 relative group lg:!-mt-24">
            <Image src={import('../assets/images/cta-building.avif')} alt="Yotek Structure"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" quality={90} />
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- Image Left / Text Right – matching reference -->
  <section class="relative bg-[#F8F8F6] w-full !py-20 lg:!py-64 overflow-visible">

    <!-- Gold Arc Decoration — single sweeping line from top-left to bottom-right -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none select-none z-0" viewBox="0 0 1440 900"
      preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M -100 100 C 500 800, 900 -200, 1540 800" stroke="#D4A843" stroke-width="18" fill="none"
        stroke-linecap="round" opacity="0.65" />
    </svg>

    <div class="w-full !px-6 lg:!px-16 !mx-auto relative z-10">
      <div class="flex flex-col lg:!flex-row items-start overflow-hidden lg:!overflow-visible">

        <!-- LEFT: Image – pushed down so heading appears above it -->
        <div class="w-full lg:!w-[55%] !shrink-0 lg:!mt-24">
          <div
            class="img-left-reveal opacity-0 translate-y-8 overflow-hidden shadow-lg aspect-[6/3] bg-gray-200 relative group w-full">
            <Image src={import('../assets/images/riau.avif')} alt="Yotek Riau"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" quality={90} />
          </div>
        </div>

        <!-- RIGHT: Text – overlaps image slightly via negative left margin -->
        <div class="w-full relative z-10 lg:!-ml-[10%]">
          <div class="txt-left-reveal opacity-0 translate-y-8">
            <h2 class="font-700 tracking-tight leading-[1.06] !mb-5 text-[#111]"
              style="font-size: clamp(2rem, 4.5vw, 58px); text-transform: none !important;">
              Ruang Kerja yang Mendorong Inovasi Nyata.
            </h2>
            <p class="text-[13px] lg:text-[14px] font-400 text-gray-500 leading-relaxed max-w-[640px]">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc vulputate libero et velit interdum, ac
              aliquet odio mattis. Class aptent taciti sociosqu ad litora torquent per conubia nostra, per inceptos
              himenaeos. Curabitur tempus urna at turpis condimentum lobortis.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- Vision & Mission — inside same section, below image+text -->
    <div
      class="w-full !px-6 lg:!px-16  !mx-auto !mt-24 lg:!mt-40 !pb-12 lg:!pb-24 border-t border-gray-200 !pt-16 lg:!pt-24">
      <div class="mx-auto">
        <div class="flex flex-col lg:flex-row w-full justify-between !gap-8 lg:!gap-16">

          <!-- Left: small label — hidden on mobile -->
          <div class="reveal hidden lg:flex lg:pt-1">
            <p class="text-[#222] font-bold text-[16px] font-800 leading-snug max-w-[240px]">
              Pondasi nilai yang memandu setiap langkah Yotek.
            </p>
          </div>

          <!-- Right: Vision + Mission stacked -->
          <div class="flex max-w-[40%] flex-col gap-10 lg:gap-12">

            <!-- Vision -->
            <div class="reveal">
              <h2 class="text-black !mb-3 text-2xl md:text-3xl lg:text-4xl font-700 tracking-tight"
                style="text-transform: none;">Vision</h2>
              <p class="text-gray-600 leading-relaxed text-[14px] lg:text-[15px] text-justify">
                Menjadi perusahaan grup terdepan yang menghadirkan solusi terintegrasi
                di berbagai sektor industri strategis dengan standar keunggulan tertinggi dan berorientasi pada masa
                depan.
              </p>
            </div>

            <!-- Mission -->
            <div class="reveal">
              <h2 class="text-black !mb-3 text-2xl md:text-3xl lg:text-4xl font-700 tracking-tight"
                style="text-transform: none;">Mission</h2>
              <div class="space-y-3">
                <p class="text-gray-600 leading-relaxed text-[14px] lg:text-[15px] text-justify">
                  Mengedepankan integritas dan profesionalisme dalam setiap lini layanan, membangun sinergi strategis
                  dan kolaborasi erat dengan seluruh stakeholder.
                </p>
                <p class="text-gray-600 leading-relaxed text-[14px] lg:text-[15px] text-justify">
                  Berinovasi secara konsisten untuk menciptakan nilai tambah yang berkelanjutan. Mengembangkan sumber
                  daya manusia yang kompeten, adaptif, dan berkarakter.
                </p>
                <p class="text-gray-600 leading-relaxed text-[14px] lg:text-[15px] text-justify">
                  Mengembangkan sumber daya manusia yang kompeten, adaptif, dan berkarakter.
                </p>
              </div>
            </div>

          </div>

        </div>
      </div>
    </div>
  </section>


    <!-- HISTORY SECTION (Ultra-Light GPU Optimized) -->
    <section id="history-section" class="relative w-full bg-black">
      <div id="history-wrapper" class="relative w-full h-screen flex items-center justify-center overflow-hidden">

        <!-- Optimized Layers Stack -->
        <div id="history-layers" class="absolute inset-0">

          <!-- Layer 1: 2015 -->
          <div
            class="history-layer absolute inset-0 opacity-1 z-10 flex items-center justify-center will-change-[opacity,transform]">
            <Image src={buildingImage} alt="2015" class="absolute inset-0 w-full h-full object-cover opacity-60"
              quality={100} />
            <div class="absolute inset-0 bg-black/40"></div>

            <div
              class="container mx-auto px-6 lg:px-16 flex flex-col lg:flex-row items-center justify-between relative z-10 w-full">
              <div class="w-full lg:w-1/2 flex justify-center lg:justify-start items-center">
                <div class="relative overflow-hidden h-[12vw] lg:h-[10vw]">
                  <span
                    class="history-year text-[12vw] lg:text-[10vw] font-800 text-white leading-none tracking-tighter inline-block">2015</span>
                </div>
              </div>
              <div class="w-full lg:w-1/2 mt-10 lg:mt-0 flex justify-center lg:justify-start">
                <div class="max-w-lg lg:ml-12">
                  <h3 class="text-3xl lg:text-4xl font-700 !text-white !mb-6 leading-tight">Awal Mula Perjalanan</h3>
                  <p class="!text-white/60 text-[16px] lg:text-[17px] leading-relaxed">Yotek memulai langkah pertamanya
                    dengan dedikasi tinggi untuk memberikan solusi teknis terbaik bagi industri di Indonesia. Fokus pada
                    kualitas dan kepercayaan pelanggan adalah kunci utama kami.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Layer 2: 2018 -->
          <div
            class="history-layer absolute inset-0 opacity-0 z-0 flex items-center justify-center will-change-[opacity,transform]">
            <Image src={riauImg} alt="2018" class="absolute inset-0 w-full h-full object-cover opacity-60"
              quality={100} />
            <div class="absolute inset-0 bg-black/40"></div>

            <div
              class="container mx-auto px-6 lg:px-16 flex flex-col lg:flex-row items-center justify-between relative z-10 w-full">
              <div class="w-full lg:w-1/2 flex justify-center lg:justify-start items-center">
                <div class="relative overflow-hidden h-[12vw] lg:h-[10vw]">
                  <span
                    class="history-year text-[12vw] lg:text-[10vw] font-800 text-white leading-none tracking-tighter inline-block">2018</span>
                </div>
              </div>
              <div class="w-full lg:w-1/2 mt-10 lg:mt-0 flex justify-center lg:justify-start">
                <div class="max-w-lg lg:ml-12">
                  <h3 class="text-3xl lg:text-4xl font-700 !text-white !mb-6 leading-tight">Ekspansi Strategis</h3>
                  <p class="!text-white/60 text-[16px] lg:text-[17px] leading-relaxed">Melihat potensi pasar yang besar,
                    Yotek melakukan ekspansi dengan membuka unit bisnis baru. Kami mulai merambah sektor industri pangan
                    dan manufaktur skala besar dengan tim ahli yang kompeten.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Layer 3: 2022 -->
          <div
            class="history-layer absolute inset-0 opacity-0 z-0 flex items-center justify-center will-change-[opacity,transform]">
            <Image src={tempBusinessImg} alt="2022" class="absolute inset-0 w-full h-full object-cover opacity-60"
              quality={100} />
            <div class="absolute inset-0 bg-black/40"></div>

            <div
              class="container mx-auto px-6 lg:px-16 flex flex-col lg:flex-row items-center justify-between relative z-10 w-full">
              <div class="w-full lg:w-1/2 flex justify-center lg:justify-start items-center">
                <div class="relative overflow-hidden h-[12vw] lg:h-[10vw]">
                  <span
                    class="history-year text-[12vw] lg:text-[10vw] font-800 text-white leading-none tracking-tighter inline-block">2022</span>
                </div>
              </div>
              <div class="w-full lg:w-1/2 mt-10 lg:mt-0 flex justify-center lg:justify-start">
                <div class="max-w-lg lg:ml-12">
                  <h3 class="text-3xl lg:text-4xl font-700 !text-white !mb-6 leading-tight">Era Inovasi Digital</h3>
                  <p class="!text-white/80 text-[16px] lg:text-[17px] leading-relaxed">Transformasi menjadi pilar utama.
                    Kami mengintegrasikan teknologi digital dalam setiap proses operasional, memastikan efisiensi
                    maksimal dan hasil yang akurat bagi seluruh mitra kami.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Layer 4: 2026 -->
          <div
            class="history-layer absolute inset-0 opacity-0 z-0 flex items-center justify-center will-change-[opacity,transform]">
            <Image src={ctaBuildingImg} alt="2026" class="absolute inset-0 w-full h-full object-cover opacity-60"
              quality={100} />
            <div class="absolute inset-0 bg-black/40"></div>

            <div
              class="container mx-auto px-6 lg:px-16 flex flex-col lg:flex-row items-center justify-between relative z-10 w-full">
              <div class="w-full lg:w-1/2 flex justify-center lg:justify-start items-center">
                <div class="relative overflow-hidden h-[12vw] lg:h-[10vw]">
                  <span
                    class="history-year text-[12vw] lg:text-[10vw] font-800 text-white leading-none tracking-tighter inline-block">2026</span>
                </div>
              </div>
              <div class="w-full lg:w-1/2 mt-10 lg:mt-0 flex justify-center lg:justify-start">
                <div class="max-w-lg lg:ml-12">
                  <h3 class="text-3xl lg:text-4xl font-700 !text-white !mb-6 leading-tight">Visi Masa Depan</h3>
                  <p class="!text-white/80 text-[16px] lg:text-[17px] leading-relaxed">Menatap masa depan dengan
                    optimisme. Yotek berkomitmen untuk terus berinnovasi dalam menghadirkan solusi yang berkelanjutan
                    dan memberikan dampak positif bagi industri nasional secara menyeluruh.</p>
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- Decorative Elements -->
        <div
          class="absolute bottom-10 left-16 z-20 flex gap-4 text-xs font-700 text-gray-400 uppercase tracking-widest invisible lg:visible">
          <span>History Timeline</span>
          <span class="w-12 h-[1px] bg-gray-300 mt-2.5"></span>
          <span id="history-index">01 / 04</span>
        </div>
      </div>
    </section>



  <!-- CEO Section -->
  <section class="section bg-[#F9F9F9] py-24">
    <div class="container mx-auto px-6 lg:px-12">
      <p class="kicker mb-4 text-center text-gray-500 font-700">Pimpinan</p>
      <h2 class="text-black mb-16 text-center text-4xl lg:text-5xl font-700 tracking-tight"
        style="text-transform: none;">Sosok di Balik Yotek</h2>

      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 max-w-5xl mx-auto items-center reveal">
        <div
          class="w-full max-w-[360px] mx-auto lg:max-w-none lg:w-2/5 aspect-[3/4] relative overflow-hidden bg-gray-200">
          <img src={CEO.image} alt={CEO.name} class="w-full h-full object-cover grayscale opacity-90" loading="lazy" />
        </div>
        <div class="w-full lg:w-3/5">
          <h3 class="text-3xl font-display font-700 text-[#111] tracking-tight mb-2">{CEO.name}</h3>
          <p class="text-[var(--color-gold)] text-sm font-display font-700 uppercase tracking-wider mb-8">{CEO.title}
          </p>
          <div class="text-gray-600 leading-relaxed space-y-4 text-[16px]">
            <p>
              Dengan pengalaman lebih dari dua dekade di industri strategis, kepemimpinan beliau telah membawa Yotek
              bertransformasi dari perusahaan lokal menjadi pemain utama berskala nasional.
            </p>
            <p>
              {CEO.bio}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { animateReveal } from '../scripts/animations';

    gsap.registerPlugin(ScrollTrigger);

    function initAboutPages() {
      // Pass imported images to client script via data attributes
      const historyEl = document.getElementById('history-section');
      const riauSrc = historyEl?.getAttribute('data-riau') || "";
      const footerBgSrc = historyEl?.getAttribute('data-footer') || "";
      const tempBusinessSrc = historyEl?.getAttribute('data-temp') || "";
      const ctaBuildingSrc = historyEl?.getAttribute('data-cta') || "";

      // Hero Animations
      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

      tl.to("#hero-title", {
        y: 0,
        opacity: 1,
        duration: 1.2,
      })
        .to("#hero-building", {
          scale: 1,
          opacity: 1,
          duration: 1.5,
        }, "-=0.6")
        .to(["#hero-text-left", "#hero-text-right"], {
          x: 0,
          opacity: 1,
          duration: 1,
          stagger: 0.2
        }, "-=1");

      // Floating parallax effect for building & texts based on mouse move
      const section = document.querySelector('section');
      if (section && !window.matchMedia('(max-width: 768px)').matches) {
        section.addEventListener('mousemove', (e) => {
          const xPos = (e.clientX / window.innerWidth - 0.5) * 20;
          const yPos = (e.clientY / window.innerHeight - 0.5) * 20;

          gsap.to("#hero-building", {
            x: xPos,
            y: yPos,
            duration: 1,
            ease: "power2.out"
          });
          gsap.to("#hero-text-left", {
            x: -xPos * 0.5,
            y: -yPos * 0.5,
            duration: 1,
          });
          gsap.to("#hero-text-right", {
            x: xPos * 0.5,
            y: -yPos * 0.5,
            duration: 1,
          });
        });
      }

      // Culture / Journey Section Animations
      gsap.fromTo(".culture-txt",
        { y: 30, opacity: 0 },
        {
          scrollTrigger: {
            trigger: "#culture-sticky-text",
            start: "top 75%",
          },
          y: 0,
          opacity: 1,
          duration: 1.2,
          stagger: 0.2,
          ease: "power4.out"
        }
      );

      gsap.to(".culture-img-card", {
        scrollTrigger: {
          trigger: ".culture-img-card",
          start: "top 85%",
        },
        y: 0,
        opacity: 1,
        duration: 1.4,
        ease: "power3.out"
      });

      // Image Left / Text Right Section Animations
      gsap.to(".img-left-reveal", {
        scrollTrigger: { trigger: ".img-left-reveal", start: "top 80%" },
        y: 0, opacity: 1, duration: 1.2, ease: "power3.out"
      });
      gsap.to(".txt-left-reveal", {
        scrollTrigger: { trigger: ".txt-left-reveal", start: "top 80%" },
        y: 0, opacity: 1, duration: 1.2, delay: 0.2, ease: "power3.out"
      });

      // --- ULTRA-LIGHT GPU OPTIMIZED HISTORY SECTION ---
      const historyLayers = gsap.utils.toArray('.history-layer');
      const historyIndex = document.getElementById('history-index');

      // Set initial states
      gsap.set(historyLayers, { opacity: 0 });
      gsap.set(historyLayers[0] as HTMLElement, { opacity: 1 });

      // Clean timeline for maximum performance
      const historyTl = gsap.timeline({
        scrollTrigger: {
          trigger: "#history-section",
          start: "top top",
          end: "+=300%",
          scrub: 1,
          pin: true,
          pinSpacing: true,
        }
      });

      historyLayers.forEach((layer, i) => {
        if (i === 0) return;

        const prevLayer = historyLayers[i - 1] as HTMLElement;
        const currentLayer = layer as HTMLElement;
        const currentYear = currentLayer.querySelector('.history-year');

        // Fast GPU Cross-fade
        historyTl.to(prevLayer, { opacity: 0, duration: 1 }, i - 0.5)
          .to(currentLayer, { opacity: 1, duration: 1 }, i - 0.5)

          // Subtle entrance to keep it 'still' but smooth
          .fromTo(currentYear, { scale: 0.95, opacity: 0 }, { scale: 1, opacity: 1, duration: 0.6 }, i - 0.2)

          .add(() => {
            if (historyIndex) historyIndex.innerText = `0${i + 1} / 04`;
          }, i - 0.1);
      });

      // Re-init reveal animations
      document.querySelectorAll('.reveal').forEach((el) => {
        animateReveal(el as HTMLElement, { y: 30 });
      });
    }

    document.addEventListener('astro:page-load', initAboutPages);
  </script>
</BaseLayout>