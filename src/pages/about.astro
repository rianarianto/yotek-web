---
/**
 * About Page — Dark Cathedral
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CEO } from '../constants/site';
---

<BaseLayout title="Tentang Kami" description="Pelajari lebih lanjut tentang PT. Yogura Tekindo, visi misi kami.">
  <!-- Header -->
  <section class="py-20 lg:py-28 bg-[var(--color-abyss)]">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="max-w-3xl">
        <p class="kicker mb-4">Tentang Kami</p>
        <h1 class="text-white mb-6">
          Tentang <span class="text-[var(--color-gold)]">YOTEK</span>
        </h1>
        <p class="text-base text-[var(--color-ash)] leading-relaxed max-w-xl">
          {SITE.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Vision & Mission -->
  <section class="section bg-[var(--color-charcoal)] border-y border-[var(--color-dark-surface)]">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <div class="reveal">
          <p class="kicker mb-4">01</p>
          <h2 class="text-white mb-6 text-3xl">Visi</h2>
          <p class="text-[var(--color-ash)] leading-relaxed text-base">
            Menjadi perusahaan group terdepan yang menghadirkan solusi terintegrasi
            di berbagai sektor industri strategis dengan standar keunggulan tertinggi.
          </p>
        </div>
        <div class="reveal">
          <p class="kicker mb-4">02</p>
          <h2 class="text-white mb-6 text-3xl">Misi</h2>
          <ul class="space-y-4">
            {[
              'Mengedepankan integritas dan profesionalisme dalam setiap layanan',
              'Membangun sinergi strategis dengan seluruh stakeholder',
              'Berinovasi untuk menciptakan nilai tambah yang berkelanjutan',
              'Mengembangkan sumber daya manusia yang kompeten dan berkarakter',
            ].map((item) => (
              <li class="flex items-start gap-3 text-[var(--color-ash)]">
                <span class="w-1.5 h-1.5 bg-[var(--color-gold)] mt-2 shrink-0"></span>
                <span class="text-sm">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CEO -->
  <section class="section bg-[var(--color-abyss)]">
    <div class="container mx-auto px-6 lg:px-12">
      <p class="kicker mb-4">Pimpinan</p>
      <h2 class="text-white mb-12">Pimpinan Perusahaan</h2>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start reveal">
        <div class="relative overflow-hidden aspect-[3/4] bg-[var(--color-charcoal)]">
          <img src={CEO.image} alt={CEO.name} class="w-full h-full object-cover opacity-80" loading="lazy" />
        </div>
        <div class="lg:col-span-2 pt-4">
          <h3 class="text-2xl font-display font-700 text-white uppercase tracking-tight mb-1">{CEO.name}</h3>
          <p class="text-[var(--color-gold)] text-sm font-display font-600 uppercase tracking-wider mb-6">{CEO.title}</p>
          <p class="text-[var(--color-ash)] leading-relaxed">{CEO.bio}</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { animateReveal } from '../scripts/animations';
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('.reveal').forEach((el) => {
        animateReveal(el as HTMLElement, { y: 30 });
      });
    });
  </script>
</BaseLayout>
