---
/**
 * Contact Page — Dark Cathedral with GSAP success state
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, FORM_ACTION } from '../constants/site';
---

<BaseLayout title="Kontak" description="Hubungi PT. Yogura Tekindo.">
  <section class="py-20 lg:py-28 bg-[var(--color-abyss)]">
    <div class="container mx-auto px-6 lg:px-12">
      <p class="kicker mb-4">Kontak</p>
      <h1 class="text-white mb-3">
        Hubungi <span class="text-[var(--color-gold)]">Kami</span>
      </h1>
      <p class="text-[var(--color-ash)] max-w-xl text-sm">Kami siap membantu Anda. Kirimkan pesan atau hubungi kami langsung.</p>
    </div>
  </section>

  <section class="pb-24 bg-[var(--color-abyss)]">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-3">
          <form id="contact-form" action={FORM_ACTION} method="POST" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-xs font-display font-600 text-[var(--color-steel)] uppercase tracking-wider mb-2">Nama Lengkap</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3.5 bg-[var(--color-charcoal)] border border-[var(--color-dark-surface)] text-white placeholder:text-[var(--color-ash)] focus:outline-none focus:border-[var(--color-gold)] transition-colors duration-300 text-sm" placeholder="Nama Anda" />
              </div>
              <div>
                <label for="email" class="block text-xs font-display font-600 text-[var(--color-steel)] uppercase tracking-wider mb-2">Email</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3.5 bg-[var(--color-charcoal)] border border-[var(--color-dark-surface)] text-white placeholder:text-[var(--color-ash)] focus:outline-none focus:border-[var(--color-gold)] transition-colors duration-300 text-sm" placeholder="email@contoh.com" />
              </div>
            </div>
            <div>
              <label for="company" class="block text-xs font-display font-600 text-[var(--color-steel)] uppercase tracking-wider mb-2">Perusahaan <span class="text-[var(--color-ash)]">(Opsional)</span></label>
              <input type="text" id="company" name="company" class="w-full px-4 py-3.5 bg-[var(--color-charcoal)] border border-[var(--color-dark-surface)] text-white placeholder:text-[var(--color-ash)] focus:outline-none focus:border-[var(--color-gold)] transition-colors duration-300 text-sm" placeholder="Nama Perusahaan" />
            </div>
            <div>
              <label for="subject" class="block text-xs font-display font-600 text-[var(--color-steel)] uppercase tracking-wider mb-2">Subjek</label>
              <select id="subject" name="subject" required class="w-full px-4 py-3.5 bg-[var(--color-charcoal)] border border-[var(--color-dark-surface)] text-white focus:outline-none focus:border-[var(--color-gold)] transition-colors duration-300 text-sm">
                <option value="">Pilih Subjek</option>
                <option value="general">Pertanyaan Umum</option>
                <option value="business">Kerjasama Bisnis</option>
                <option value="career">Lamaran Kerja</option>
                <option value="media">Media & Pers</option>
                <option value="other">Lainnya</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-xs font-display font-600 text-[var(--color-steel)] uppercase tracking-wider mb-2">Pesan</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3.5 bg-[var(--color-charcoal)] border border-[var(--color-dark-surface)] text-white placeholder:text-[var(--color-ash)] focus:outline-none focus:border-[var(--color-gold)] transition-colors duration-300 text-sm resize-none" placeholder="Tuliskan pesan Anda..."></textarea>
            </div>
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
            <button type="submit" id="submit-btn" class="btn-gold">
              <span id="btn-text">Kirim Pesan</span>
              <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg>
              <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3" /><path d="M4 12a8 8 0 0 1 8-8" stroke="currentColor" stroke-width="3" stroke-linecap="round" /></svg>
            </button>
          </form>
          <!-- Success -->
          <div id="success-state" class="hidden text-center py-20">
            <div class="w-16 h-16 bg-[var(--color-gold)] flex items-center justify-center mx-auto mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[var(--color-abyss)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
            </div>
            <h3 class="text-2xl font-display font-700 text-white mb-3 uppercase">Pesan Terkirim</h3>
            <p class="text-[var(--color-ash)] max-w-md mx-auto text-sm">Terima kasih telah menghubungi kami. Tim kami akan segera merespon pesan Anda.</p>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2">
          <div class="sticky top-28 space-y-8">
            <div>
              <h4 class="text-xs font-display font-600 uppercase tracking-[0.15em] text-[var(--color-steel)] mb-3">Alamat</h4>
              <p class="text-sm text-white">{SITE.address}</p>
            </div>
            <div class="divider"></div>
            <div>
              <h4 class="text-xs font-display font-600 uppercase tracking-[0.15em] text-[var(--color-steel)] mb-3">Email</h4>
              <a href={`mailto:${SITE.email}`} class="text-sm text-white hover:text-[var(--color-gold)] transition-colors">{SITE.email}</a>
            </div>
            <div class="divider"></div>
            <div>
              <h4 class="text-xs font-display font-600 uppercase tracking-[0.15em] text-[var(--color-steel)] mb-3">Telepon</h4>
              <a href={`tel:${SITE.phone}`} class="text-sm text-white hover:text-[var(--color-gold)] transition-colors">{SITE.phone}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import gsap from 'gsap';
    function initContactForm() {
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      const successState = document.getElementById('success-state');
      const submitBtn = document.getElementById('submit-btn');
      const btnText = document.getElementById('btn-text');
      const btnIcon = document.getElementById('btn-icon');
      const btnSpinner = document.getElementById('btn-spinner');
      if (!form || !successState || !submitBtn) return;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitBtn.setAttribute('disabled', 'true');
        if (btnText) btnText.textContent = 'Mengirim...';
        if (btnIcon) btnIcon.classList.add('hidden');
        if (btnSpinner) btnSpinner.classList.remove('hidden');
        try {
          const formData = new FormData(form);
          const response = await fetch(form.action, { method: 'POST', body: formData, headers: { Accept: 'application/json' } });
          if (response.ok) {
            gsap.to(form, { opacity: 0, y: -20, duration: 0.5, ease: 'power3.out', onComplete: () => {
              form.classList.add('hidden');
              successState.classList.remove('hidden');
              gsap.fromTo(successState, { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' });
            }});
          } else { throw new Error('Failed'); }
        } catch {
          submitBtn.removeAttribute('disabled');
          if (btnText) btnText.textContent = 'Kirim Pesan';
          if (btnIcon) btnIcon.classList.remove('hidden');
          if (btnSpinner) btnSpinner.classList.add('hidden');
          alert('Terjadi kesalahan. Silakan coba lagi.');
        }
      });
    }
    document.addEventListener('astro:page-load', initContactForm);
  </script>
</BaseLayout>
