---
/**
 * Contact Page — Dark Cathedral with GSAP success state
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, FORM_ACTION } from '../constants/site';
---

<BaseLayout title="Contact Us | Yotek" description="Get in touch with PT. Yogura Tekindo. We are ready to help you with industrial solutions and business partnerships.">
  
  <!-- PREMIUM CONTACT HERO -->
  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 bg-[#F8F8F6] overflow-hidden">
    <div class="container mx-auto px-6 lg:px-16 relative z-10">
      <div class="max-w-4xl">
        <p class="reveal text-[13px] font-800 uppercase tracking-widest text-gray-400 mb-6">
          Contact Us
        </p>
        <h1 class="reveal text-black font-700 leading-tight tracking-[-0.03em] mb-8"
          style="font-size: clamp(2.5rem, 6vw, 80px); text-transform: none !important;">
          Mari Berdiskusi & <br />
          <span class="text-gray-400">Wujudkan Sinergi.</span>
        </h1>
        <div class="reveal w-20 h-1 bg-black/10"></div>
      </div>
    </div>

    <!-- Decorative Element (Abstract Arc) -->
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-[0.03] pointer-events-none translate-x-1/4">
       <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
         <path d="M500,250 C400,100 100,100 0,250" stroke="black" stroke-width="1" fill="none" />
       </svg>
    </div>
  </section>

  <!-- CONTACT FORM & INFO -->
  <section class="pb-32 bg-[#F8F8F6]">
    <div class="container mx-auto px-6 lg:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
        
        <!-- Sidebar Info (Left/First on Mobile) -->
        <div class="lg:col-span-4 order-2 lg:order-1">
          <div class="contact-sidebar space-y-12 lg:sticky lg:top-32">
            <div>
              <h4 class="text-[11px] font-800 uppercase tracking-widest text-black/40 mb-6">Headquarters</h4>
              <p class="text-xl font-700 text-black leading-snug">
                {SITE.address}
              </p>
            </div>

            <div class="w-12 h-[1px] bg-black/10"></div>

            <div>
              <h4 class="text-[11px] font-800 uppercase tracking-widest text-black/40 mb-6">Direct Contact</h4>
              <div class="space-y-4">
                <a href={`mailto:${SITE.email}`} class="block text-xl font-700 text-black hover:text-[#B89456] transition-colors duration-300">
                  {SITE.email}
                </a>
                <a href={`tel:${SITE.phone}`} class="block text-xl font-700 text-black hover:text-[#B89456] transition-colors duration-300">
                  {SITE.phone}
                </a>
              </div>
            </div>

            <div class="w-12 h-[1px] bg-black/10"></div>

            <div>
              <h4 class="text-[11px] font-800 uppercase tracking-widest text-black/40 mb-6">Social Connection</h4>
              <div class="flex gap-6">
                <a href="#" class="text-[13px] font-800 uppercase tracking-widest text-black hover:opacity-50 transition-opacity">LinkedIn</a>
                <a href="#" class="text-[13px] font-800 uppercase tracking-widest text-black hover:opacity-50 transition-opacity">Instagram</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Form Area (Right/Main) -->
        <div class="lg:col-span-8 order-1 lg:order-2">
          <div class="bg-white !p-8 lg:!p-16 shadow-xl shadow-black/[0.03] border border-gray-100 reveal-form">
            <form id="contact-form" action={FORM_ACTION} method="POST" class="space-y-8">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                  <label for="name" class="text-[11px] font-800 uppercase tracking-widest text-black/30">Nama Lengkap</label>
                  <input type="text" id="name" name="name" required class="w-full bg-gray-50 border-b border-gray-200 !px-0 !py-4 text-black font-600 focus:outline-none focus:border-black transition-all placeholder:text-gray-300 placeholder:font-400" placeholder="John Doe" />
                </div>
                <div class="space-y-2">
                  <label for="email" class="text-[11px] font-800 uppercase tracking-widest text-black/30">Alamat Email</label>
                  <input type="email" id="email" name="email" required class="w-full bg-gray-50 border-b border-gray-200 !px-0 !py-4 text-black font-600 focus:outline-none focus:border-black transition-all placeholder:text-gray-300 placeholder:font-400" placeholder="john@example.com" />
                </div>
              </div>

              <div class="space-y-2">
                <label for="subject" class="text-[11px] font-800 uppercase tracking-widest text-black/30">Keperluan</label>
                <select id="subject" name="subject" required class="w-full bg-gray-50 border-b border-gray-200 !px-0 !py-4 text-black font-600 focus:outline-none focus:border-black transition-all appearance-none cursor-pointer">
                  <option value="">Pilih Subjek</option>
                  <option value="business">Kerjasama Bisnis</option>
                  <option value="project">Pertanyaan Proyek</option>
                  <option value="career">Karir & Rekrutmen</option>
                  <option value="other">Lainnya</option>
                </select>
              </div>

              <div class="space-y-2">
                <label for="message" class="text-[11px] font-800 uppercase tracking-widest text-black/30">Pesan Anda</label>
                <textarea id="message" name="message" rows="4" required class="w-full bg-gray-50 border-b border-gray-200 !px-0 !py-4 text-black font-600 focus:outline-none focus:border-black transition-all resize-none placeholder:text-gray-300 placeholder:font-400" placeholder="Bagaimana kami bisa membantu Anda?"></textarea>
              </div>

              <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
              
              <div class="pt-6">
                <button type="submit" id="submit-btn" class="group relative flex items-center gap-4 bg-black text-white !px-10 !py-5 text-[13px] font-800 uppercase tracking-widest hover:bg-gray-800 transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed overflow-hidden">
                  <span id="btn-text" class="relative z-10 transition-transform duration-500 group-hover:translate-x-1">Kirim Pesan</span>
                  <svg id="btn-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 relative z-10 transition-transform duration-500 group-hover:translate-x-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                  <svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3" />
                    <path d="M4 12a8 8 0 0 1 8-8" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                  </svg>
                </button>
              </div>
            </form>

            <!-- Success State -->
            <div id="success-state" class="hidden text-center py-16">
              <div class="w-20 h-20 bg-green-50 text-green-600 flex items-center justify-center mx-auto mb-8 rounded-full">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-3xl font-700 text-black mb-4 tracking-tight">Pesan Berhasil Terkirim</h3>
              <p class="text-gray-500 text-[16px] max-w-sm mx-auto leading-relaxed">
                Terima kasih telah menghubungi Yotek. Tim kami akan segera meninjau pesan Anda dan merespon dalam waktu dekat.
              </p>
              <button onclick="window.location.reload()" class="mt-10 text-[12px] font-800 uppercase tracking-widest text-[#B89456] hover:text-black transition-colors">Kirim Pesan Lainnya</button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { animateReveal } from '../scripts/animations';

    gsap.registerPlugin(ScrollTrigger);

    function initContactPage() {
      // Reveal items on load
      document.querySelectorAll('.reveal').forEach((el) => {
        animateReveal(el as HTMLElement, { y: 30, duration: 1.2 });
      });

      // Reveal Sidebar & Form on scroll
      gsap.to([".contact-sidebar > div", ".reveal-form"], {
        scrollTrigger: {
          trigger: ".contact-sidebar",
          start: "top 80%",
        },
        y: 0,
        opacity: 1,
        duration: 1.2,
        stagger: 0.15,
        ease: "power3.out"
      });

      // Form Handling
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      const successState = document.getElementById('success-state');
      const submitBtn = document.getElementById('submit-btn');
      const btnText = document.getElementById('btn-text');
      const btnIcon = document.getElementById('btn-icon');
      const btnSpinner = document.getElementById('btn-spinner');

      if (!form || !successState || !submitBtn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitBtn.setAttribute('disabled', 'true');
        if (btnText) btnText.textContent = 'Mengirim...';
        if (btnIcon) btnIcon.classList.add('hidden');
        if (btnSpinner) btnSpinner.classList.remove('hidden');

        try {
          const formData = new FormData(form);
          const response = await fetch(form.action, { method: 'POST', body: formData, headers: { Accept: 'application/json' } });
          
          if (response.ok) {
            gsap.to(form, { 
              opacity: 0, 
              y: -20, 
              duration: 0.6, 
              ease: 'power3.out', 
              onComplete: () => {
                form.classList.add('hidden');
                successState.classList.remove('hidden');
                gsap.fromTo(successState, 
                  { opacity: 0, scale: 0.95 }, 
                  { opacity: 1, scale: 1, duration: 0.8, ease: 'back.out(1.7)' }
                );
              }
            });
          } else { throw new Error('Failed'); }
        } catch {
          submitBtn.removeAttribute('disabled');
          if (btnText) btnText.textContent = 'Kirim Pesan';
          if (btnIcon) btnIcon.classList.remove('hidden');
          if (btnSpinner) btnSpinner.classList.add('hidden');
          alert('Terjadi kesalahan. Silakan coba lagi.');
        }
      });
    }

    document.addEventListener('astro:page-load', initContactPage);
  </script>

  <style>
    .contact-sidebar > div, .reveal-form {
      opacity: 0;
      transform: translateY(30px);
    }
  </style>
</BaseLayout>

</BaseLayout>
