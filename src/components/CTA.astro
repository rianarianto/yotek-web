---
/**
 * CTA Section — Call to Action
 * Encouraging partnerships and contact.
 */
import { SITE } from '../constants/site';
---

<section class="relative py-32 lg:py-48 bg-[#F8F8F8] overflow-hidden w-full flex justify-center">
  <div class="max-w-[1200px] w-full mx-auto px-6 lg:px-12 text-center text-reveal-trigger">
    
    <!-- Decorative element -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 bg-gradient-to-b from-gray-200 to-transparent"></div>

    <div class="flex flex-col items-center">
      <span class="text-[11px] uppercase font-800 text-[var(--color-gold)] tracking-[0.3em] mb-8 block opacity-0 translate-y-4 cta-element">
        Ready to Collaborate
      </span>
      
      <h2 class="text-3xl md:text-5xl lg:text-[56px] font-800 leading-[1.1] tracking-[-0.03em] text-black mb-10 max-w-4xl opacity-0 translate-y-8 cta-element" style="text-transform: none !important;">
        Membangun Masa Depan Berkelanjutan Bersama YOTEK.
      </h2>
      
      <p class="text-base md:text-lg text-gray-500 font-500 leading-relaxed max-w-2xl mb-12 opacity-0 translate-y-8 cta-element">
        Kami siap menjadi mitra strategis Anda dalam menghadirkan solusi inovatif dan integritas tinggi di berbagai sektor industri inti.
      </p>

      <div class="opacity-0 translate-y-10 cta-element">
        <a 
          href="/contact" 
          class="inline-block px-10 py-5 bg-black text-white font-700 text-sm uppercase tracking-wider rounded-sm transition-all duration-500 hover:bg-[var(--color-gold)] hover:-translate-y-1 hover:shadow-2xl shadow-xl"
        >
          Hubungi Kami Sejauh Ini
        </a>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initCTA() {
    gsap.to(".cta-element", {
      scrollTrigger: {
        trigger: ".text-reveal-trigger",
        start: "top 75%",
      },
      y: 0,
      opacity: 1,
      duration: 1.2,
      stagger: 0.15,
      ease: "power4.out"
    });
  }

  document.addEventListener('astro:page-load', initCTA);
</script>
