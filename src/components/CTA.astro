---
/**
* CTA Section — Call to Action
* Overlapping Layout (100% matched to bleeding reference mockup)
*/
import { Image } from 'astro:assets';
import buildingImage from '../assets/images/cta-building.avif';
---

<section id="cta-section" class="relative w-full h-[90vh] lg:h-[110vh] bg-[#F8F8F6] overflow-hidden flex items-center">
  <div class="container mx-auto px-6 lg:px-16 relative z-10">
    
    <div class="flex flex-col lg:flex-row items-center justify-between gap-20">
      
      <!-- Text Side -->
      <div class="cta-text-content w-full lg:w-1/2 flex flex-col items-center lg:items-start text-center lg:text-left gap-8">
        <p class="cta-reveal opacity-0 translate-y-4 text-[13px] font-800 uppercase tracking-[0.4em] text-[#B89456]">Ready to Lead?</p>
        
        <h2 class="cta-reveal opacity-0 translate-y-8 text-[44px] md:text-[60px] lg:text-[84px] font-700 text-black leading-[1] tracking-[-0.05em] !mb-4">
          Mari Membangun <br/>
          <span class="text-gray-300">Era Masa Depan.</span>
        </h2>
        
        <p class="cta-reveal opacity-0 translate-y-8 text-[16px] lg:text-[18px] text-gray-500 font-500 leading-relaxed max-w-lg">
          Kami siap menjadi mitra strategis Anda dalam menghadirkan solusi inovatif yang melampaui standar industri demi pertumbuhan yang berkelanjutan.
        </p>

        <div class="cta-reveal opacity-0 translate-y-8 mt-4">
          <a href="/contact" class="group flex items-center gap-6 text-[14px] font-800 uppercase tracking-widest text-black">
            <span class="bg-black text-white px-10 py-5 group-hover:bg-[#B89456] transition-colors duration-500">Hubungi Kami</span>
            <div class="w-12 h-[1px] bg-black/20 relative overflow-hidden transition-all group-hover:w-16">
               <div class="absolute inset-0 bg-black translate-x-[-101%] group-hover:translate-x-0 transition-transform duration-500"></div>
            </div>
          </a>
        </div>
      </div>

      <!-- Image Side (Architectural Asset) -->
      <div class="cta-image-wrapper relative w-full lg:w-1/2 flex justify-center lg:justify-end">
        <div class="relative w-full max-w-[600px] aspect-[4/5] overflow-hidden shadow-2xl shadow-black/10">
          <Image src={buildingImage} alt="Yotek Vision" format="avif" quality={100}
            class="cta-img opacity-0 scale-110 w-full h-full object-cover" />
          <div class="absolute inset-0 bg-black/5"></div>
        </div>
        
        <!-- Decoration Box -->
        <div class="absolute -bottom-10 -left-10 w-40 h-40 border border-black/5 -z-10 hidden lg:block"></div>
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initCTA() {
    const section = document.querySelector('#cta-section');
    if (!section) return;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 70%",
      }
    });

    tl.to(".cta-reveal", {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power4.out"
    });

    tl.to(".cta-img", {
      opacity: 1,
      scale: 1,
      duration: 1.5,
      ease: "power2.out"
    }, "-=1");
  }

  document.addEventListener('astro:page-load', initCTA);
</script>

<style>
  .cta-text-content {
    will-change: transform, opacity;
  }
</style>