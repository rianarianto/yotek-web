---
/**
* About Brief Section — Typographic Branding
* A clean, bold section highlighting the company mission with high-contrast typography.
*/
---

<!-- Penggunaan min-h-[100vh] dan items-center secara native meletakkan konten di tengah layar tanpa script -->
<section id="about-brief-section"
  class="relative min-h-[100vh] py-20 bg-[#F9F9F9] overflow-hidden w-full flex items-center justify-center"
  style="will-change: transform;">
  <!-- Ganti max-w-[1500px] ini untuk mengatur seberapa lebar halamannya -->
  <!-- Semakin besar angkanya, semakin lebar (kurang ke tengah) posisinya -->
  <div class="w-full !px-6 lg:!px-16">
    <div class="flex flex-col-reverse lg:flex-row justify-between items-start gap-12 lg:gap-24">

      <!-- Left Content: Primary Message -->
      <div class="w-full lg:w-[70%] flex flex-col items-start gap-12">
        <!-- GSAP will split this text into individual words for the scroll effect -->
        <h2 id="about-brief-text"
          class="text-3xl md:text-5xl lg:!text-[46px] font-700 leading-[1.3] tracking-[-0.02em] text-[#D1D1D1]"
          style="text-transform: none !important;">Kami hadir untuk menyatukan berbagai lini bisnis dalam visi
          memberikan solusi industri yang transparan, inovatif, dan bertanggung jawab.</h2>

        <!-- Call to Action (Hidden awalnya lalu muncul pas teks di tengah) -->
        <div id="about-btn-wrapper" class="opacity-0 translate-y-6">
          <a href="/about"
            class="inline-flex items-center gap-3 bg-[#111] text-white uppercase tracking-[0.2em] !px-8 !py-4 text-[14px] hover:bg-[#FDF7EB] outline-1 hover:text-[#111] transition-colors duration-300 w-fit mx-auto lg:mx-0 group mt-2 shadow-lg">
            Pelajari Lebih Jauh
          </a>
        </div>
      </div>

      <!-- Right Content: Accent Text -->
      <div class="w-full lg:w-[25%] flex lg:justify-end lg:pt-4">
        <p class="text-[16px] font-800 text-gray-500 tracking-normal" style="text-transform: none !important;">
          Integritas dan Kepercayaan
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  /* Refined typography precision */
  h2 {
    font-family: 'Manrope', sans-serif;
  }

  /* GPU layer promotion untuk mencegah scroll jank pada animasi warna kata */
  .brief-word {
    will-change: color;
    display: inline;
  }

  @media (max-width: 1024px) {
    .lg\:writing-vertical-rl {
      writing-mode: horizontal-tb;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAboutBrief() {
    const textEl = document.getElementById('about-brief-text');
    const sectionEl = document.getElementById('about-brief-section');
    if (!textEl || !sectionEl) return;

    // Pisah teks per kata jika belum di-split
    if (!textEl.hasAttribute('data-split')) {
      const words = textEl.innerText.split(' ');
      textEl.innerHTML = '';
      words.forEach((word) => {
        const span = document.createElement('span');
        span.innerText = word + ' ';
        // Default font jadi abu-abu muda dulu (akan menggelap kena scroll)
        span.className = 'brief-word inline text-[#D1D1D1]';
        textEl.appendChild(span);
      });
      textEl.setAttribute('data-split', 'true');
    }

    // GSAP ScrollTrigger sistem Pinned (stuck di layar)
    // SOLUSI HENTAKAN: anticipatePin membuat GSAP mempersiapkan pin lebih awal sehingga tidak ada lompatan
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top top',          // Menempel tanpa hentakan sejak batas atas section menyentuh atas layar
        end: '+=250%',             // Durasi scroll virtual
        pin: true,                 // Pin secara mulus
        scrub: 1.5,                // Interpolasi mulus
        pinSpacing: true,          // Mengatur jarak otomatis
        anticipatePin: 1,          // FIX: Menghilangkan hentakan saat pinning dimulai
        fastScrollEnd: true,       // FIX: Mencegah overshoot saat scroll cepat
      }
    });

    // Animasikan perubahan warna kata-per-kata selagi elemen sedang menempel (pinned)
    tl.to('.brief-word', {
      color: '#000000',
      stagger: 0.1,
      ease: 'power2.inOut',
      duration: 0.8,
      force3D: true,               // FIX: Paksa GPU layer untuk animasi lebih smooth
    });

    // Animasi Button
    gsap.to('#about-btn-wrapper', {
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top top',          // Sync persis saat layar mulai pinned
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: 'power3.out'
    });
  }

  document.addEventListener('astro:page-load', initAboutBrief);
</script>