---
/**
* About Brief Section — Typographic Branding
* A clean, bold section highlighting the company mission with high-contrast typography.
*/
---

<section class="relative py-24 lg:py-40 bg-[#F9F9F9] overflow-hidden">
  <div class="w-[94%] max-w-[1600px] mx-auto">
    <div class="flex flex-col lg:flex-row justify-between items-start gap-12 lg:gap-24">

      <!-- Left Content: Primary Message -->
      <div class="w-full lg:w-[80%]">
        <h2 class="text-3xl md:text-5xl lg:!text-[48px] font-700 leading-[1.2] tracking-[-0.03em] mb-12 normal-case">
          <span class="text-black inline">Kami hadir untuk menyatukan</span>
          <span class="text-[#888888] inline"> berbagai lini bisnis dalam visi memberikan solusi industri yang
            transparan, inovatif, dan bertanggung jawab.</span>
        </h2>

        <!-- Call to Action -->
        <a href="/about"
          class="inline-block bg-[#1a1a1a] text-white !px-10 !py-4 text-[14px] font-700 tracking-wider uppercase transition-all duration-300 hover:bg-black hover:scale-105">
          Pelajari Lebih Jauh
        </a>
      </div>

      <!-- Right Content: Accent Text -->
      <div class="lg:pt-2">
        <p
          class="text-[13px] lg:text-[14px] font-600 text-gray-400 whitespace-nowrap lg:writing-vertical-rl tracking-[0.2em] uppercase opacity-70">
          Integritas dan Kepercayaan
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  /* Refined typography precision */
  h2 {
    font-family: 'Manrope', sans-serif;
  }

  @media (max-width: 1024px) {
    .lg\:writing-vertical-rl {
      writing-mode: horizontal-tb;
    }
  }
</style>