---
/**
* About Brief Section — Typographic Branding
* A clean, bold section highlighting the company mission with high-contrast typography.
*/
---

<section class="relative py-24 lg:!py-40 bg-[#F9F9F9] overflow-hidden w-full flex justify-center">
  <!-- Ganti max-w-[1500px] ini untuk mengatur seberapa lebar halamannya -->
  <!-- Semakin besar angkanya, semakin lebar (kurang ke tengah) posisinya -->
  <div class="w-full !px-6 lg:!px-16">
    <div class="flex flex-col lg:flex-row justify-between items-start gap-12 lg:gap-24">

      <!-- Left Content: Primary Message -->
      <div class="w-full lg:w-[70%] flex flex-col items-start gap-12">
        <!-- GSAP will split this text into individual words for the scroll effect -->
        <h2 id="about-brief-text"
          class="text-3xl md:text-5xl lg:!text-[46px] font-700 leading-[1.3] tracking-[-0.02em] text-[#D1D1D1]"
          style="text-transform: none !important;">Kami hadir untuk menyatukan berbagai lini bisnis dalam visi
          memberikan solusi industri yang transparan, inovatif, dan bertanggung jawab.</h2>

        <!-- Call to Action -->
        <a href="/about"
          class="inline-block bg-black text-white !px-8 !py-3.5 text-[14px] font-600 transition-all duration-300 hover:bg-[#333333] normal-case tracking-normal">
          Pelajari Lebih Jauh
        </a>
      </div>

      <!-- Right Content: Accent Text -->
      <div class="w-full lg:w-[25%] flex lg:justify-end lg:pt-4">
        <p class="text-[16px] font-800 text-gray-500 tracking-normal" style="text-transform: none !important;">
          Integritas dan Kepercayaan
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  /* Refined typography precision */
  h2 {
    font-family: 'Manrope', sans-serif;
  }

  @media (max-width: 1024px) {
    .lg\:writing-vertical-rl {
      writing-mode: horizontal-tb;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAboutBrief() {
    const textEl = document.getElementById('about-brief-text');
    if (!textEl) return;

    // Pisah teks per kata jika belum di-split
    if (!textEl.hasAttribute('data-split')) {
      const words = textEl.innerText.split(' ');
      textEl.innerHTML = '';
      words.forEach((word) => {
        const span = document.createElement('span');
        span.innerText = word + ' ';
        // Default font jadi abu-abu muda dulu (akan menggelap kena scroll)
        span.className = 'brief-word inline text-[#D1D1D1]';
        textEl.appendChild(span);
      });
      textEl.setAttribute('data-split', 'true');
    }

    // GSAP ScrollTrigger untuk mewarnai kata demi kata
    gsap.to('.brief-word', {
      scrollTrigger: {
        trigger: textEl,
        start: 'top 80%',
        end: 'bottom 40%',
        scrub: 1,
      },
      color: '#000000', // Berubah jadi Hitam
      stagger: 0.1,
      ease: 'none'
    });
  }

  document.addEventListener('astro:page-load', initAboutBrief);
</script>