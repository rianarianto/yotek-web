---
/**
* About Brief Section — Typographic Branding
* A clean, bold section highlighting the company mission with high-contrast typography.
*/
---

<!-- Penggunaan min-h-[100vh] dan items-center secara native meletakkan konten di tengah layar tanpa script -->
<section id="about-brief-section"
  class="relative min-h-[100vh] py-32 lg:py-48 bg-white overflow-hidden w-full flex items-center justify-center">
  
  <div class="w-full !px-6 lg:!px-16 container mx-auto">
    <div class="flex flex-col lg:flex-row justify-between items-start gap-16 lg:gap-32">

      <!-- Left Content: Primary Message -->
      <div class="w-full lg:w-[75%] flex flex-col items-start gap-16">
        <p class="opacity-80 text-[13px] font-800 uppercase tracking-[0.4em] text-[#B89456]">Our Purpose</p>
        
        <!-- GSAP will split this text into individual words for the scroll effect -->
        <h2 id="about-brief-text"
          class="text-3xl md:text-5xl lg:text-[62px] font-700 leading-[1.1] tracking-[-0.04em] text-[#E5E5E5]"
          style="text-transform: none !important;">
          Kami hadir untuk menyatukan berbagai lini bisnis dalam visi memberikan solusi industri yang transparan, inovatif, dan bertanggung jawab bagi masa depan yang lebih baik.
        </h2>

        <!-- Call to Action -->
        <div id="about-btn-wrapper" class="opacity-0 translate-y-8">
          <a href="/about" class="group flex items-center gap-6 text-[14px] font-800 uppercase tracking-widest text-black">
            <span class="bg-black text-white px-10 py-5 group-hover:bg-[#B89456] transition-colors duration-500">Learn More</span>
            <div class="w-12 h-[1px] bg-black/20 relative overflow-hidden transition-all group-hover:w-16">
               <div class="absolute inset-0 bg-black translate-x-[-101%] group-hover:translate-x-0 transition-transform duration-500"></div>
            </div>
          </a>
        </div>
      </div>

      <!-- Right Content: Brand Accent -->
      <div class="w-full lg:w-[20%] flex lg:justify-end">
        <div class="flex flex-col gap-4 border-l border-black/10 pl-8 lg:pl-12">
          <p class="text-[13px] font-800 uppercase tracking-widest text-black mb-2">Philosophy</p>
          <p class="text-[15px] font-500 text-gray-500 leading-relaxed" style="text-transform: none !important;">
            Integritas dan Kepercayaan adalah mata uang kami dalam membangun transparansi di setiap sektor industri.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* GPU layer promotion for smooth scroll color transition */
  .brief-word {
    will-change: color;
    display: inline;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAboutBrief() {
    const textEl = document.getElementById('about-brief-text');
    const sectionEl = document.getElementById('about-brief-section');
    if (!textEl || !sectionEl) return;

    // Split text into words if not already done
    if (!textEl.hasAttribute('data-split')) {
      const words = textEl.innerText.split(' ');
      textEl.innerHTML = '';
      words.forEach((word) => {
        const span = document.createElement('span');
        span.innerText = word + ' ';
        span.className = 'brief-word inline text-[#E5E5E5]';
        textEl.appendChild(span);
      });
      textEl.setAttribute('data-split', 'true');
    }

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: sectionEl,
        start: 'top top',
        end: '+=200%',
        pin: true,
        scrub: 1.2,
        anticipatePin: 1,
      }
    });

    // Animate color change word by word
    tl.to('.brief-word', {
      color: '#000000',
      stagger: 0.1,
      ease: 'none',
    });

    // Reveal button after some scroll
    gsap.to('#about-btn-wrapper', {
      scrollTrigger: {
        trigger: sectionEl,
        start: 'center center',
      },
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: "power3.out"
    });
  }

  document.addEventListener('astro:page-load', initAboutBrief);
</script>