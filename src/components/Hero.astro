---
/**
* Hero Section — Stage 17 (Pure Design Imitation)
* Menggunakan sistem Layer (Absolute) untuk memastikan elemen saling menimpa
* tepat seperti imajinasi user dan referensi desain.
*/
import { SITE } from '../constants/site';
---

<section class="relative w-full h-[110vh] lg:h-[115vh] bg-[#F8F8F8] overflow-hidden">

  <!-- STAGE: Full width stage without restrictive container -->
  <div class="relative w-full h-full mx-auto">

    <!-- LAYER 1: HEADING -->
    <div id="hero-title-parallax"
      class="absolute top-[18%] md:top-[12%] lg:top-[12%] left-1/2 -translate-x-1/2 w-full text-center z-0 !px-4 !py-4">
      <div class="hero-title-wrapper overflow-hidden pb-4">
        <h1 class="font-800 leading-[0.9] tracking-tighter uppercase hero-title" id="hero-title">
          Yogura Tekindo
        </h1>
      </div>
    </div>

    <!-- LAYER 2: GLOBE -->
    <div id="globe-parallax"
      class="absolute top-[12%] md:top-[8%] lg:top-[10%] left-1/2 -translate-x-1/2 w-[180%] max-w-[800px] md:w-full md:max-w-[800px] lg:max-w-[1000px] aspect-square z-10 pointer-events-none">
      <img src="/images/globe.png" id="hero-globe" alt="Yotek Global"
        class="w-full h-full object-contain globe-visual opacity-0 scale-90" />
    </div>

    <!-- LAYER 3: TAGLINE -->
    <div id="tagline-parallax"
      class="absolute top-[64%] md:top-[65%] lg:top-[64%] left-1/2 -translate-x-1/2 w-full text-center px-6 z-20">
      <p class="text-[24px] font-bold md:text-2xl lg:text-3xl font-800 text-[#1a1a1a] leading-[1.2] tracking-tight opacity-0"
        id="hero-tagline">
        Integritas dalam Sinergi.<br />
        Keunggulan di Setiap Sektor.
      </p>
    </div>

    <!-- LAYER 4: ARROW -->
    <div class="absolute bottom-40 left-1/2 -translate-x-1/2 z-30 opacity-0" id="hero-arrow">
      <div class="flex flex-col items-center gap-2 text-gray-400">
        <span class="text-[10px] uppercase tracking-[0.3em] font-700">Explore</span>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"
          class="arrow-icon">
          <path d="M12 5V19M12 19L5 12M12 19L19 12" stroke="#EAAE36" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round" />
        </svg>
      </div>
    </div>

  </div>

</section>

<style>
  /* Base Desktop Styling */
  .hero-title {
    font-size: 11.5vw;
    color: #1a1a1a;
    letter-spacing: -0.051em;
    display: block;
    white-space: nowrap;
    will-change: opacity, transform;
    transform: translateY(110%);
    /* Start hidden below the mask */
  }

  /* Mobile Only Isolation */
  @media (max-width: 767px) {
    .hero-title {
      font-size: clamp(3rem, 11vw, 5rem);
      white-space: normal;
      line-height: 1;
    }
  }

  /* Bounce Animation */
  .arrow-icon {
    animation: bounce 2s infinite;
  }

  @keyframes bounce {

    0%,
    20%,
    50%,
    80%,
    100% {
      transform: translateY(0);
    }

    40% {
      transform: translateY(-5px);
    }

    60% {
      transform: translateY(-3px);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initHeroDesign() {
    gsap.killTweensOf("#hero-title, #hero-globe, #hero-tagline, #hero-arrow");

    const tl = gsap.timeline({ defaults: { ease: "power4.out", duration: 1.8 } });

    // 1. Masked Text Reveal (Professional Agency Style)
    tl.to("#hero-title", {
      translateY: 0,
      duration: 2,
      ease: "power4.out"
    });

    // 2. Globe Smooth Appearance
    tl.to("#hero-globe", {
      opacity: 1,
      scale: 1,
      duration: 2.5
    }, "-=1.7");

    // 3. Tagline Appearance
    tl.to("#hero-tagline", {
      opacity: 1,
      y: -10,
      duration: 1.5
    }, "-=2.2");

    tl.to("#hero-arrow", {
      opacity: 1,
      duration: 1
    }, "-=1.5");

    // --- INFINITE AMBIENT ANIMATION ---
    // Smooth 3D-like float & rotation
    gsap.to("#hero-globe", {
      y: 25,
      rotationY: 15,
      duration: 6,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });

    // --- PARALLAX EFFECTS ON SCROLL ---
    // Globe Parallax (Moves slightly slower/down)
    gsap.to("#globe-parallax", {
      y: 100,
      scrollTrigger: {
        trigger: "section",
        start: "top top",
        end: "bottom top",
        scrub: true
      }
    });

    // Tagline Parallax (Moves faster up)
    gsap.to("#tagline-parallax", {
      y: -150,
      scrollTrigger: {
        trigger: "section",
        start: "top top",
        end: "bottom top",
        scrub: true
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    initHeroDesign();
  });
</script>