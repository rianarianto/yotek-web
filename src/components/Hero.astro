---
/**
* Hero Section — Stage 17 (Pure Design Imitation)
* Menggunakan sistem Layer (Absolute) untuk memastikan elemen saling menimpa
* tepat seperti imajinasi user dan referensi desain.
*/
import { SITE } from '../constants/site';
import { Image } from 'astro:assets';
import globeImg from '../assets/images/globe.png';
---

<section class="relative w-full h-[100vh] lg:h-[110vh] bg-[#F8F8F6] overflow-hidden flex items-center justify-center">
  
  <!-- STAGE: Full width stage -->
  <div class="relative w-full h-full container mx-auto px-6">

    <!-- LAYER 1: HEADING (Massive Background Title) -->
    <div id="hero-title-parallax"
      class="absolute top-[20%] md:top-[15%] lg:top-[12%] left-1/2 -translate-x-1/2 w-full text-center z-0">
      <div class="hero-title-wrapper overflow-hidden select-none">
        <h1 class="hero-title font-900 leading-[0.85] tracking-[-0.06em] text-black" id="hero-title">
          Yogura Tekindo
        </h1>
      </div>
    </div>

    <!-- LAYER 2: GLOBE (Floating Central Piece) -->
    <div id="globe-parallax"
      class="absolute top-[15%] md:top-[10%] lg:top-[12%] left-1/2 -translate-x-1/2 w-[160%] max-w-[700px] md:w-[90%] md:max-w-[750px] lg:max-w-[950px] aspect-square z-10 pointer-events-none">
      <Image src={globeImg} id="hero-globe" alt="Yotek Global" format="avif" quality={100}
        class="w-full h-full object-contain globe-visual opacity-0 scale-90" loading="eager" />
      
      <!-- Subtle Ambient Glow -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#B89456]/5 to-transparent rounded-full blur-[100px]"></div>
    </div>

    <!-- LAYER 3: TAGLINE & CALL TO ACTION -->
    <div id="tagline-parallax"
      class="absolute top-[68%] md:top-[68%] lg:top-[72%] left-1/2 -translate-x-1/2 w-full text-center px-6 z-20 flex flex-col items-center gap-12">
      <div class="overflow-hidden">
        <p class="hero-reveal text-[20px] md:text-[24px] lg:text-[32px] font-700 text-black leading-tight tracking-tight opacity-0 translate-y-full"
          id="hero-tagline">
          Integritas dalam Sinergi. <br class="md:hidden"/>
          <span class="text-gray-400">Keunggulan di Setiap Sektor.</span>
        </p>
      </div>

      <div class="hero-reveal opacity-0 translate-y-8">
        <a href="#about-brief-section" class="group flex items-center justify-center gap-4 text-[13px] font-900 uppercase tracking-[0.3em] text-black">
          Discover Our Impact
          <div class="w-10 h-[1.5px] bg-black/10 relative overflow-hidden transition-all group-hover:w-16">
             <div class="absolute inset-0 bg-black translate-x-[-101%] group-hover:translate-x-0 transition-transform duration-500"></div>
          </div>
        </a>
      </div>
    </div>

    <!-- LAYER 4: SCROLL INDICATOR -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-30 opacity-0" id="hero-scroll">
      <div class="flex flex-col items-center gap-4">
        <div class="w-[1px] h-20 bg-gradient-to-b from-black/20 via-black to-transparent animate-scroll-line"></div>
      </div>
    </div>

  </div>

</section>

<style>
  .hero-title {
    font-size: 14vw;
    will-change: transform, opacity;
    transform: translateY(100%);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 18vw;
      white-space: normal;
      line-height: 0.9;
    }
  }

  @keyframes scroll-line {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    50.1% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  .animate-scroll-line {
    animation: scroll-line 2.5s cubic-bezier(0.77, 0, 0.175, 1) infinite;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initHero() {
    gsap.killTweensOf("#hero-title, #hero-globe, .hero-reveal, #hero-scroll");

    const tl = gsap.timeline({ defaults: { ease: "power4.out" } });

    // 1. Title Reveal
    tl.to("#hero-title", {
      y: 0,
      duration: 2,
      delay: 0.5
    });

    // 2. Globe Smooth Appearance
    tl.to("#hero-globe", {
      opacity: 1,
      scale: 1,
      duration: 2.5
    }, "-=1.5");

    // 3. Tagline & CTA reveal
    tl.to(".hero-reveal", {
      opacity: 1,
      y: 0,
      duration: 1.5,
      stagger: 0.2
    }, "-=1.8");

    // 4. Scroll Indicator
    tl.to("#hero-scroll", {
      opacity: 1,
      duration: 1.5
    }, "-=1");

    // --- AMBIENT ---
    gsap.to("#hero-globe", {
      y: 20,
      rotationY: 10,
      duration: 5,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });

    // --- PARALLAX ---
    gsap.to("#globe-parallax", {
      y: 150,
      scrollTrigger: {
        trigger: "section",
        start: "top top",
        end: "bottom top",
        scrub: true
      }
    });

    gsap.to("#hero-title", {
      y: 80,
      scrollTrigger: {
        trigger: "section",
        start: "top top",
        end: "bottom top",
        scrub: true
      }
    });
  }

  document.addEventListener('astro:page-load', initHero);
</script>