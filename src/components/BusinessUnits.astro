---
/**
* Business Units Section
* Showcasing different units with an asymmetrical staggered layout.
* Refined for premium mobile responsiveness.
*/
import { Image } from 'astro:assets';
import tempUnitImg from '../assets/images/temp_business_unit.jpg';

const units = [
  {
    title: "Industrial Services & Maintenance",
    company: "PT Indo Riau Perkasa",
    image: tempUnitImg,
    width: "lg:w-[600px]",
    aspect: "aspect-[4/5]",
    align: "justify-center lg:ml-[20%]",
    mt: "",
    mobileOffset: ""
  },
  {
    title: "Formal Education Services",
    company: "JR Education",
    image: tempUnitImg,
    width: "lg:w-[500px]",
    aspect: "aspect-[4/5]",
    align: "justify-end lg:mr-[5%]",
    mt: "lg:-mt-40",
    mobileOffset: "pl-[10%]"
  },
  {
    title: "Property & Real Estate",
    company: "PT Hunian Hijau Indonesia",
    image: tempUnitImg,
    width: "lg:w-[460px]",
    aspect: "aspect-[4/5]",
    align: "justify-center lg:ml-[14%]",
    mt: "lg:-mt-48",
    mobileOffset: ""
  },
  {
    title: "Advertising & Printing Materials",
    company: "PT Sumber Display Dunia",
    image: tempUnitImg,
    width: "lg:w-[480px]",
    aspect: "aspect-[4/5]",
    align: "justify-start lg:!ml-[8%]",
    mt: "lg:-mt-40",
    mobileOffset: "pr-[10%]"
  },
  {
    title: "Security System Integration",
    company: "PT Sanyus Hutama",
    image: tempUnitImg,
    width: "lg:w-[440px]",
    aspect: "aspect-[4/5]",
    align: "justify-end lg:mr-[10%]",
    mt: "lg:-mt-52",
    mobileOffset: "pl-[5%]"
  },
  {
    title: "Electric Vehicle Charging Infrastructure",
    company: "Dayagreen",
    image: tempUnitImg,
    width: "lg:w-[460px]",
    aspect: "aspect-[4/5]",
    align: "justify-center lg:mr-[5%]",
    mt: "lg:-mt-40",
    mobileOffset: ""
  }
];
---

<section id="business-units" class="relative !py-32 lg:py-64 bg-[#FDFDFD] overflow-hidden w-full">
  <div class="w-full mx-auto px-6 lg:px-16">
    
    <!-- Section Title -->
    <div class="max-w-4xl !mb-32 lg:!mb-48">
      <p class="unit-reveal text-[13px] font-800 uppercase tracking-widest text-[#B89456] !mb-6 opacity-0 translate-y-4">Core Ecosystem</p>
      <h2 class="unit-reveal text-[40px] md:text-[64px] font-700 tracking-[-0.04em] text-black leading-[1.1] opacity-0 translate-y-8">
        Sinergi Unit Bisnis <br/>
        <span class="text-gray-300">Lintas Sektor & Industri.</span>
      </h2>
    </div>

    <!-- Container Utama: Menggunakan sistem tumpuk asimetris -->
    <div class="flex flex-col gap-32 lg:gap-48 relative">
      {units.map((unit, index) => (
      <div class={`business-unit-item flex w-full ${unit.align} ${unit.mt} opacity-0 relative ${unit.mobileOffset}`}
        style={`z-index: ${10 + index};`}>

        <div class="flex flex-col lg:flex-row items-start lg:items-center gap-10 lg:gap-20 w-full lg:w-auto group">
          <!-- Image Container with Parallax -->
          <div class={`w-full ${unit.width} overflow-hidden ${unit.aspect} relative bg-[#F8F8F6] shadow-2xl shadow-black/5`}>
            
            <Image 
              src={unit.image} 
              alt={unit.title}
              format="avif"
              quality={90}
              class="unit-parallax-img w-full h-[130%] object-cover absolute top-[-15%] grayscale hover:grayscale-0 transition-all duration-1000" 
            />

            <!-- Subtle Overlay -->
            <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors duration-700"></div>
            
            <!-- Index Number (Subtle) -->
            <div class="absolute bottom-8 right-8 z-10">
              <span class="text-[60px] font-900 leading-none text-white/20 tracking-tighter">0{index + 1}</span>
            </div>
          </div>

          <!-- Text Content -->
          <div class="w-full lg:max-w-[420px] flex flex-col gap-6">
            <div class="overflow-hidden">
              <span
                class="unit-kicker text-[12px] uppercase font-800 text-[#B89456] tracking-[0.3em] block translate-y-full">
                {unit.title}
              </span>
            </div>
            <div class="overflow-hidden">
              <h3
                class="unit-title text-3xl md:text-4xl lg:text-[42px] font-700 leading-[1.1] text-black tracking-tight translate-y-full"
                style="text-transform: none !important;">
                {unit.company}
              </h3>
            </div>
            <div class="pt-4 border-t border-black/5">
              <a href="/business" class="group/btn flex items-center gap-4 text-[13px] font-800 uppercase tracking-widest text-black">
                Explore Unit
                <div class="w-10 h-[1.5px] bg-black/10 relative overflow-hidden transition-all group-hover/btn:w-14">
                   <div class="absolute inset-0 bg-black translate-x-[-101%] group-hover/btn:translate-x-0 transition-transform duration-500"></div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initBusinessUnits() {
    const items = document.querySelectorAll('.business-unit-item');

    items.forEach((item) => {
      // 1. Entrance Animation (Whole Item)
      gsap.to(item, {
        scrollTrigger: {
          trigger: item,
          start: "top 85%",
        },
        opacity: 1,
        y: 0,
        duration: 1.2,
        ease: "power3.out"
      });

      // 2. Text Reveal (Staggered inside the item)
      const kicker = item.querySelector('.unit-kicker');
      const title = item.querySelector('.unit-title');
      const desc = item.querySelector('.unit-desc');

      if (kicker && title && desc) {
        gsap.to([kicker, title, desc], {
          y: 0,
          duration: 1,
          stagger: 0.1,
          ease: "power4.out",
          scrollTrigger: {
            trigger: item,
            start: "top 80%",
          }
        });
      }

      // 3. Parallax Effect on Image
      const img = item.querySelector('.unit-parallax-img');
      if (img) {
        gsap.to(img, {
          y: "15%", // Increased parallax depth
          scrollTrigger: {
            trigger: item,
            start: "top bottom",
            end: "bottom top",
            scrub: true
          },
          ease: "none"
        });
      }
    });
  }

  // Handle both initial load and view transitions
  document.addEventListener('astro:page-load', initBusinessUnits);
</script>

<style>
  .business-unit-item {
    transform: translateY(60px);
    transition: opacity 0.5s ease;
  }
</style>