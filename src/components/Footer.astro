---
/**
* Footer — Atmospheric Minimalist
* Immersive full-bleed background with massive typographic brand overlay.
* Exact match to custom reference.
*/
import { SITE } from '../constants/site';
import { Image } from 'astro:assets';
// Image di-import secara otomatis untuk optimasi Astro:Assets
import footerBgSrc from '../assets/images/footer-bg.avif';

const currentYear = new Date().getFullYear();
---

<footer class="relative w-full h-[60vh] min-h-[500px] lg:h-[80vh] bg-[#111] overflow-hidden flex flex-col justify-end">

  <!-- BACKGROUND IMAGE (Fixed Parallax via Clip Path) -->
  <!-- Metode ini menjamin kualitas gambar (HD) 100% utuh lewat komponen native Astro tanpa pecah -->
  <div class="absolute inset-0 w-full h-full z-0 pointer-events-none" style="clip-path: inset(0);">
    <Image src={footerBgSrc} alt="Yotek Environments" quality={100}
      class="fixed top-0 left-0 w-full h-[100vh] object-cover opacity-60 mix-blend-luminosity" loading="lazy" />
  </div>

  <!-- MASSIVE OVERLAY TEXT ('YOTEK') -->
  <!-- Teks raksasa yang responsif, posisinya diatur agar menimpa area gelap footer -->
  <div class="absolute inset-x-0 bottom-[2%] lg:bottom-[-16%] flex justify-end items-end pointer-events-none">
    <h1
      class="footer-yotek-text !text-[32vw] lg:!text-[24vw] font-800 !text-white/20 tracking-tight leading-[0.75] uppercase select-none">
      YOTEK
    </h1>
  </div>

  <!-- BOTTOM UTILITY LINKS -->
  <!-- Konsisten dengan desain: Rata kiri bawah, font minimalis -->
  <div
    class="relative z-10 w-full !px-6 lg:!px-12 !pb-8 flex flex-col sm:flex-row items-start sm:items-center justify-start gap-4 sm:gap-8 text-white/80 text-[13px] md:text-[14px] font-500 tracking-wide">
    <p>&copy;{currentYear}, {SITE.fullName}</p>

    <div class="flex items-center gap-6">
      <a href="/privacy" class="transition-colors hover:text-white">Kebijakan Privasi</a>
      <a href="/terms" class="transition-colors hover:text-white">Syarat & Ketentuan</a>
    </div>
  </div>

</footer>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initFooter() {
    const footer = document.querySelector('footer');
    const footerText = document.querySelector('.footer-yotek-text');
    if (!footer || !footerText) return;

    gsap.from(footerText, {
      y: 100,
      opacity: 0,
      filter: 'blur(15px)',
      duration: 2,
      ease: 'power4.out',
      scrollTrigger: {
        trigger: footer,
        start: 'top 85%', // Animasi mulai saat footer masuk area layar
        once: true
      }
    });

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', initFooter);
</script>