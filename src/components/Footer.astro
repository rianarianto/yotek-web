---
/**
 * Footer — Dark Iron Surface
 * Charcoal surface rising from the abyss.
 */
import { SITE, NAV_LINKS, SOCIAL } from '../constants/site';
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#111111] text-white overflow-hidden">
  <!-- Main Footer -->
  <div class="max-w-[1400px] mx-auto px-6 lg:px-16 py-20 lg:py-28">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 lg:gap-12">
      
      <!-- Brand & Description -->
      <div class="lg:col-span-2">
        <h2 class="text-3xl font-800 tracking-tighter text-white mb-6 uppercase">
          {SITE.name}<span class="text-[var(--color-gold)]">.</span>
        </h2>
        <p class="text-gray-400 max-w-md leading-relaxed mb-10 text-[15px] font-500">
          {SITE.description}
        </p>
        
        <!-- Social Icons -->
        <div class="flex items-center gap-4">
          {Object.entries(SOCIAL).map(([name, url]) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-11 h-11 border border-gray-800 flex items-center justify-center rounded-full transition-all duration-500 hover:bg-[var(--color-gold)] hover:border-[var(--color-gold)] hover:text-black text-gray-400 group"
              aria-label={name}
            >
              {name === 'instagram' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg>
              )}
              {name === 'linkedin' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" /></svg>
              )}
              {name === 'facebook' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" /></svg>
              )}
              {name === 'youtube' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z" /><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" /></svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-[11px] font-800 uppercase tracking-[0.25em] text-gray-500 mb-8">
          Navigation
        </h4>
        <ul class="flex flex-col gap-4">
          {NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[15px] font-500 text-gray-400 transition-colors duration-300 hover:text-[var(--color-gold)]"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="text-[11px] font-800 uppercase tracking-[0.25em] text-gray-500 mb-8">
          Connect
        </h4>
        <ul class="flex flex-col gap-6 text-[15px] text-gray-400 font-500">
          <li class="flex items-start gap-4">
             <div class="mt-1 w-5 h-5 text-[var(--color-gold)] shrink-0">
               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
             </div>
            <span class="leading-relaxed">{SITE.address}</span>
          </li>
          <li class="flex items-center gap-4 group">
            <div class="w-5 h-5 text-[var(--color-gold)] shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
            </div>
            <a href={`mailto:${SITE.email}`} class="transition-colors duration-300 group-hover:text-[var(--color-gold)]">{SITE.email}</a>
          </li>
          <li class="flex items-center gap-4 group">
            <div class="w-5 h-5 text-[var(--color-gold)] shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
            </div>
            <a href={`tel:${SITE.phone}`} class="transition-colors duration-300 group-hover:text-[var(--color-gold)]">{SITE.phone}</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="border-t border-gray-900">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-16 py-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-[13px] text-gray-500 font-500">
        &copy; {currentYear} {SITE.fullName}. <span class="hidden md:inline">Designed for Excellence.</span>
      </p>
      <p class="text-[11px] text-gray-600 tracking-[0.2em] font-800 uppercase">
        Integritas dalam Sinergi
      </p>
    </div>
  </div>
</footer>
