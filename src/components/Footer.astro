---
/**
 * Footer — Dark Iron Surface
 * Charcoal surface rising from the abyss.
 */
import { SITE, NAV_LINKS, SOCIAL } from '../constants/site';
const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--color-iron)] border-t border-[var(--color-dark-surface)]">
  <!-- Main Footer -->
  <div class="container mx-auto px-6 lg:px-12 py-16 lg:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <img
          src="/images/logo-white.png"
          alt={SITE.fullName}
          class="h-8 w-auto mb-6"
          loading="lazy"
        />
        <p class="text-[var(--color-ash)] max-w-md leading-relaxed mb-8 text-sm">
          {SITE.description}
        </p>
        <!-- Social Icons -->
        <div class="flex items-center gap-3">
          {Object.entries(SOCIAL).map(([name, url]) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 bg-[var(--color-dark-surface)] flex items-center justify-center transition-all duration-300 hover:bg-[var(--color-gold)] hover:text-[var(--color-abyss)] text-[var(--color-steel)]"
              aria-label={name}
            >
              {name === 'instagram' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg>
              )}
              {name === 'linkedin' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" /></svg>
              )}
              {name === 'facebook' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" /></svg>
              )}
              {name === 'youtube' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z" /><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" /></svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-xs font-display font-600 uppercase tracking-[0.15em] text-[var(--color-steel)] mb-6">
          Navigasi
        </h4>
        <ul class="flex flex-col gap-3">
          {NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-[var(--color-ash)] transition-colors duration-300 hover:text-[var(--color-gold)]"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs font-display font-600 uppercase tracking-[0.15em] text-[var(--color-steel)] mb-6">
          Kontak
        </h4>
        <ul class="flex flex-col gap-4 text-sm text-[var(--color-ash)]">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-[var(--color-gold)] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
            <span>{SITE.address}</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-[var(--color-gold)] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
            <a href={`mailto:${SITE.email}`} class="transition-colors duration-300 hover:text-[var(--color-gold)]">{SITE.email}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-[var(--color-gold)] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
            <a href={`tel:${SITE.phone}`} class="transition-colors duration-300 hover:text-[var(--color-gold)]">{SITE.phone}</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-[var(--color-dark-surface)]">
    <div class="container mx-auto px-6 lg:px-12 py-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[var(--color-ash)]">
        &copy; {currentYear} {SITE.fullName}. All rights reserved.
      </p>
      <p class="text-xs text-[var(--color-ash)] tracking-wide uppercase">
        Integritas dalam Sinergi
      </p>
    </div>
  </div>
</footer>
