---
/**
* Latest News Section
* A clean, carousel-based section displaying items with Swiper.js.
* Features top-right navigation and a centered responsive layout.
*/
import { getCollection } from 'astro:content';

interface Props {
limit?: number;
}

const { limit = 8 } = Astro.props; // Increased limit for carousel

const allNews = await getCollection('news');
const latestNews = allNews
.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
.slice(0, limit);
---

<section id="latest-news" class="!py-24 lg:!py-32 bg-[#F8F8F6] w-full overflow-hidden">
  <div class="w-full !px-6 lg:!px-16 mx-auto">

    <!-- Section Header with Navigation -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end !mb-12 lg:!mb-20 gap-8">
      <div class="max-w-2xl">
        <p class="news-header-title opacity-0 translate-y-4 text-[13px] font-800 uppercase tracking-widest text-[#B89456] mb-4">Insights & Updates</p>
        <h2 class="news-header-title opacity-0 translate-y-4 text-[32px] md:text-[48px] font-700 tracking-[-0.03em] text-black leading-[1.1]"
          style="text-transform: none !important;">
          Torehan Jejak & <br/>
          <span class="text-gray-400">Inovasi Terbaru.</span>
        </h2>
      </div>

      <div class="flex items-center gap-6 opacity-0 translate-y-4 news-header-controls">
        <a href="/news"
          class="hidden sm:inline-flex items-center gap-2 text-[13px] font-800 uppercase tracking-widest text-black hover:opacity-50 transition-all border-b-2 border-black/10 pb-1">
          Explore All News
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <!-- Navigation Buttons -->
        <div class="flex items-center gap-3">
          <button id="news-prev"
            class="w-12 h-12 flex items-center justify-center border border-black/10 rounded-full text-black transition-all duration-300 hover:border-black hover:bg-black hover:text-white disabled:opacity-20 disabled:cursor-not-allowed group">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button id="news-next"
            class="w-12 h-12 flex items-center justify-center border border-black/10 rounded-full text-black transition-all duration-300 hover:border-black hover:bg-black hover:text-white disabled:opacity-20 disabled:cursor-not-allowed group">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Swiper Carousel - Premium Centered Experience -->
    <div class="swiper news-swiper opacity-0 translate-y-8 w-full">
      <div class="swiper-wrapper">
        {latestNews.map((post) => (
        <div class="swiper-slide">
          <a href={`/news/${post.id}`} class="news-card group block">
            <div class="relative aspect-[4/5] mb-8 overflow-hidden bg-gray-100 shadow-sm border border-black/5">
              {post.data.image ? (
              <img src={post.data.image} alt={post.data.title} loading="lazy"
                class="w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 group-hover:scale-110" />
              ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-300 bg-gray-50">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              )}
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500"></div>
              
              <!-- Date Badge -->
              <div class="absolute top-6 left-6 z-10">
                <span class="bg-white/90 backdrop-blur-sm shadow-sm !px-4 !py-2 text-[10px] font-800 uppercase tracking-widest text-black">
                  {new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                </span>
              </div>
            </div>

            <div class="space-y-4">
              <h3 class="text-[22px] font-700 leading-tight text-black line-clamp-3 group-hover:text-gray-600 transition-colors duration-300">
                {post.data.title}
              </h3>
              <p class="text-[14px] text-gray-500 leading-relaxed line-clamp-2">
                {post.data.description}
              </p>
            </div>
          </a>
        </div>
        ))}
      </div>

      <!-- Mobile Button -->
      <div class="!mt-12 sm:hidden text-center opacity-0 translate-y-4 news-mobile-btn">
        <a href="/news"
          class="inline-flex items-center justify-center bg-black text-white px-10 py-4 text-[13px] font-800 uppercase tracking-widest shadow-lg">
          View All news
        </a>
      </div>
    </div>

  </div>
</section>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Swiper from 'swiper';
  import { Navigation } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';

  gsap.registerPlugin(ScrollTrigger);

  function initLatestNews() {
    const section = document.querySelector('#latest-news');
    if (!section) return;

    // 1. Initialize Swiper
    const swiper = new Swiper('.news-swiper', {
      modules: [Navigation],
      slidesPerView: 1.2,
      spaceBetween: 24,
      grabCursor: true,
      navigation: {
        prevEl: '#news-prev',
        nextEl: '#news-next',
      },
      centeredSlides: true,
      initialSlide: 0,
      watchSlidesProgress: true,
      breakpoints: {
        640: {
          slidesPerView: 3,
          spaceBetween: 24,
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 50,
        },
        1280: {
          slidesPerView: 3,
          spaceBetween: 60,
        }
      }
    });

    // 2. Animations
    const title = section.querySelector('.news-header-title');
    const controls = section.querySelector('.news-header-controls');
    const swiperEl = section.querySelector('.news-swiper');
    const mobileBtn = section.querySelector('.news-mobile-btn');

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 80%',
      }
    });

    // Header reveal
    tl.to([title, controls], {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: 'power3.out'
    });

    // Swiper reveal
    tl.to(swiperEl, {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power4.out'
    }, "-=0.4");

    if (mobileBtn) {
      tl.to(mobileBtn, {
        opacity: 1,
        y: 0,
        duration: 0.6
      }, "-=0.2");
    }
  }

  // Handle both initial load and view transitions
  document.addEventListener('astro:page-load', initLatestNews);
</script>

<style>
  .swiper {
    width: 100%;
    overflow: visible !important;
    /* Allows slides to bleed out to the right edge as they start from the page center */
  }

  .swiper-slide {
    height: auto;
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    opacity: 0.4;
    transform: scale(0.85);
    /* Non-active slides are smaller */
  }

  .swiper-slide-active {
    opacity: 1;
    transform: scale(1);
    /* Active slide is full size */
  }

  .news-card {
    will-change: transform, opacity;
    transition: all 0.5s ease;
  }

  .swiper-slide-active .news-card img {
    grayscale: 0;
    /* Active slide is in color */
  }

  .news-card h3 {
    text-wrap: balance;
  }

  @supports not (-webkit-line-clamp: 3) {
    .line-clamp-3 {
      overflow: hidden;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
    }
  }
</style>