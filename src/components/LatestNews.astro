---
/**
* Latest News Section
* A clean, carousel-based section displaying items with Swiper.js.
* Features top-right navigation and a centered responsive layout.
*/
import { getCollection } from 'astro:content';

interface Props {
limit?: number;
}

const { limit = 8 } = Astro.props; // Increased limit for carousel

const allNews = await getCollection('news');
const latestNews = allNews
.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
.slice(0, limit);

const formatDate = (date: Date) => {
return new Date(date).toLocaleDateString('id-ID', {
day: 'numeric',
month: 'long',
year: 'numeric'
});
};
---

<section id="latest-news" class="!py-24 lg:!py-32 bg-[#F8F8F8] w-full overflow-hidden">
  <div class="w-full !px-6 lg:!px-16 mx-auto">

    <!-- Section Header mit Navigation -->
    <div class="flex flex-row justify-between items-center !mb-12 lg:!mb-16 gap-8">
      <div class="flex flex-col gap-3">
        <h2
          class="news-header-title text-[32px] md:text-[42px] font-700 tracking-[-0.02em] text-[#1A1A1A] leading-tight opacity-0 translate-y-4"
          style="text-transform: none !important;">
          Berita Terbaru
        </h2>
        <p
          class="news-subtitle hidden lg:block text-[14px] lg:text-[16px] text-gray-500 font-medium max-w-[500px] leading-relaxed opacity-0 translate-y-4">
          Informasi terkini mengenai inovasi, kabar perusahaan, dan perkembangan proyek strategis kami secara global.
        </p>
      </div>

      <div class="flex items-center gap-4 opacity-0 translate-y-4 news-header-controls">
        <!-- View All Button -->
        <a href="/news"
          class="inline-flex items-center gap-3 bg-[#111] text-white uppercase tracking-[0.2em] !px-4 !py-2 text-[10px] font-800 hover:bg-[#FDF7EB] outline-1 hover:text-[#111] transition-colors duration-300 w-fit mx-auto lg:!px-8 lg:!py-4 lg:mx-0 group mt-2 shadow-lg">
          Lihat Semua
        </a>

        <!-- Navigation Buttons -->
        <div class="flex items-center gap-2">
          <button id="news-prev"
            class="w-11 h-11 flex items-center justify-center border border-[#1A1A1A] text-[#1A1A1A] transition-all duration-300 hover:bg-[#1A1A1A] hover:text-white disabled:opacity-20 disabled:cursor-not-allowed group">
            <svg xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-1" fill="none"
              viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button id="news-next"
            class="w-11 h-11 flex items-center justify-center border border-[#1A1A1A] text-[#1A1A1A] transition-all duration-300 hover:bg-[#1A1A1A] hover:text-white disabled:opacity-20 disabled:cursor-not-allowed group">
            <svg xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none"
              viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Swiper Carousel - Premium Centered Experience -->
    <div class="swiper news-swiper opacity-0 translate-y-8 w-full" data-cursor="drag">
      <div class="swiper-wrapper">
        {latestNews.map((post, index) => (
        <div class="swiper-slide">
          <a href={`/news/${post.id}`} class="news-card group block">
            <div class="relative aspect-square mb-6 overflow-hidden bg-gray-200">
              {post.data.image ? (
              <img src={post.data.image} alt={post.data.title} loading="lazy"
                class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110" />
              ) : (
              <div
                class="w-full h-full flex items-center justify-center text-gray-400 bg-gray-100 grayscale transition-all duration-700 group-hover:grayscale-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24"
                  stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              )}
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500"></div>
            </div>

            <div class="flex flex-col gap-3 !py-8">
              <span class="text-[10px] font-800 uppercase tracking-[0.2em] text-[#1A1A1A]">
                {post.data.category || 'Berita'}
              </span>
              <h3
                class="text-[18px] lg:text-[22px] font-700 leading-[1.3] text-[#333333] transition-colors duration-300 group-hover:text-black line-clamp-3"
                style="text-transform: none !important;">
                {post.data.title}
              </h3>
              <p class="text-[12px] font-600 uppercase tracking-widest text-gray-500">
                {formatDate(post.data.pubDate)}
              </p>
            </div>
          </a>
        </div>
        ))}
      </div>

    </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Swiper from 'swiper';
  import { Navigation, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';
  import 'swiper/css/autoplay';

  gsap.registerPlugin(ScrollTrigger);

  function initLatestNews() {
    const section = document.querySelector('#latest-news');
    if (!section) return;

    // 1. Initialize Swiper
    const swiper = new Swiper('.news-swiper', {
      modules: [Navigation, Autoplay],
      slidesPerView: 1.2,
      spaceBetween: 24,
      grabCursor: true,
      loop: false,
      speed: 1200, // Slow transition speed for "soft" feel
      autoplay: {
        delay: 2000, // Delay between slides
        disableOnInteraction: false, // Continue after user interaction
        pauseOnMouseEnter: false, // Pause when user hovers
      },
      navigation: {
        prevEl: '#news-prev',
        nextEl: '#news-next',
      },
      centeredSlides: true,
      initialSlide: 0,
      watchSlidesProgress: true,
      breakpoints: {
        640: {
          slidesPerView: 3,
          spaceBetween: 24,
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 50,
        },
        1280: {
          slidesPerView: 3,
          spaceBetween: 60,
        }
      }
    });

    // 2. Animations
    const title = section.querySelector('.news-header-title');
    const subtitle = section.querySelector('.news-subtitle');
    const controls = section.querySelector('.news-header-controls');
    const swiperEl = section.querySelector('.news-swiper');
    const mobileBtn = section.querySelector('.news-mobile-btn');

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 80%',
      }
    });

    // Header reveal
    tl.to([title, subtitle, controls], {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power3.out'
    });

    // Swiper reveal
    tl.to(swiperEl, {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: 'power4.out'
    }, "-=0.4");

    if (mobileBtn) {
      tl.to(mobileBtn, {
        opacity: 1,
        y: 0,
        duration: 0.6
      }, "-=0.2");
    }
  }

  // Handle both initial load and view transitions
  document.addEventListener('astro:page-load', initLatestNews);
</script>

<style>
  .swiper {
    width: 100%;
    overflow: visible !important;
    /* Allows slides to bleed out to the right edge as they start from the page center */
  }

  .swiper-wrapper {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
  }

  .swiper-slide {
    height: auto;
    width: 85%;
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    opacity: 0.6;
    /* Increased visibility of inactive slides */
    transform: scale(0.9);
    /* Less aggressive scaling */
  }

  .swiper-slide-active {
    opacity: 1;
    transform: scale(1);
    /* Active slide is full size */
  }

  .news-card {
    will-change: transform, opacity;
    transition: all 0.5s ease;
  }

  .swiper-slide-active .news-card img {
    grayscale: 0;
    /* Active slide is in color */
  }

  .news-card h3 {
    text-wrap: balance;
  }

  @supports not (-webkit-line-clamp: 3) {
    .line-clamp-3 {
      overflow: hidden;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
    }
  }
</style>