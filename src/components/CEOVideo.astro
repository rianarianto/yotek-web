---
/**
* CEO Video Section — Immersive Vision
* Featuring a premium video player, interactive GSAP animations,
* and a sophisticated quote area.
*/
---

<section class="relative py-32 lg:py-64 bg-white overflow-hidden" id="ceo-section">
  <div class="container mx-auto px-6 lg:px-16 relative z-10">
    <div class="max-w-[1400px] mx-auto text-center !mb-24 lg:!mb-32">
      <p class="ceo-reveal opacity-0 text-[13px] font-800 uppercase tracking-[0.4em] text-[#B89456] !mb-8">Visionary Leadership</p>
      <h2 class="ceo-reveal opacity-0 text-[32px] md:text-[56px] lg:text-[72px] font-700 text-black leading-[1.1] tracking-[-0.04em]">
        Membangun Masa Depan <br/>
        <span class="text-gray-300">Lewat Integritas & Sinergi.</span>
      </h2>
    </div>

    <div class="max-w-[1200px] mx-auto relative">
      <!-- Main Video Container -->
      <div class="relative group opacity-0 scale-95" id="ceo-video-container">
        <!-- Video Frame -->
        <div class="relative aspect-video overflow-hidden shadow-2xl shadow-black/10 bg-[#F8F8F6]">
          <!-- Thumbnail Image -->
          <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=100&w=2000"
            alt="CEO Vision"
            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />

          <!-- Subtle Overlay -->
          <div class="absolute inset-0 bg-black/10 group-hover:bg-black/5 transition-colors duration-700"></div>

          <!-- Play Button (Premium) -->
          <button class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20 group/play cursor-pointer"
            aria-label="Play CEO Video">
            <div class="relative w-24 h-24 lg:w-32 lg:h-32 bg-white rounded-full flex items-center justify-center shadow-2xl transition-all duration-500 group-hover/play:scale-110 group-hover/play:bg-black">
              <div id="play-pulse" class="absolute inset-0 bg-black/10 rounded-full z-0"></div>
              <svg class="w-8 h-8 lg:w-10 lg:h-10 text-black group-hover/play:text-white fill-current relative z-10 translate-x-1"
                viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </button>
        </div>

        <!-- CEO Label (Modern Minimalist) -->
        <div class="absolute -bottom-8 -right-4 lg:-bottom-12 lg:-right-8 bg-white !p-8 lg:!p-10 shadow-2xl border border-black/5 z-30 max-w-[320px] text-right"
          id="ceo-tag">
          <p class="text-[24px] font-700 text-black leading-tight mb-2 tracking-tight">Oyong Wisman</p>
          <div class="w-12 h-[2px] bg-[#B89456] ml-auto mb-4"></div>
          <p class="text-[11px] font-800 text-gray-400 uppercase tracking-[0.2em]">Chief Executive Officer</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initCEOVideo() {
    const section = document.querySelector('#ceo-section');
    if (!section) return;

    // 1. Entrance Animation
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 60%",
      }
    });

    tl.to(".ceo-reveal", {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power4.out"
    });

    tl.to("#ceo-video-container", {
      opacity: 1,
      scale: 1,
      duration: 1.5,
      ease: "power4.out"
    }, "-=1");

    tl.from("#ceo-tag", {
      x: 60,
      opacity: 0,
      duration: 1.2,
      ease: "power3.out"
    }, "-=1");

    // 2. Continuous Play Button Pulse
    gsap.to("#play-pulse", {
      scale: 1.5,
      opacity: 0,
      duration: 2.5,
      repeat: -1,
      ease: "power1.out"
    });

    // 3. Subtle Parallax for UI
    gsap.to("#ceo-tag", {
      y: -60,
      scrollTrigger: {
        trigger: section,
        start: "top bottom",
        end: "bottom top",
        scrub: true
      }
    });
  }

  document.addEventListener('astro:page-load', initCEOVideo);
</script>