---
/**
* Achievement Section
* Showcasing company statistics / achievements.
* Design: Asymmetrical layout with sticky text on the right and scrolling cards on the left.
*/
---

<section class="relative !py-32 lg:!py-64 bg-white w-full flex justify-center overflow-hidden">
  <div class="w-full !px-6 lg:!px-16 max-w-[1600px] mx-auto">
    <div class="flex flex-col-reverse lg:flex-row justify-between !gap-16 lg:!gap-32 relative">

      <!-- Left Group: Achievement Cards -->
      <div class="w-full lg:w-[55%] flex lg:justify-center">
        <div class="w-full lg:max-w-[700px] flex flex-col !gap-12 md:!gap-20" id="achievement-cards">

          <!-- Card 1 -->
          <div
            class="bg-[#F8F8F6] border border-black/5 !p-12 md:!p-16 lg:!p-20 flex flex-col justify-between achievement-card opacity-0 translate-y-10 group rounded-none shadow-sm transition-all duration-700 hover:bg-black hover:border-black">
            <div class="flex justify-between items-start !mb-16 md:!mb-24">
              <h3 class="font-900 tracking-[-0.05em] leading-none text-black group-hover:text-white transition-colors duration-500" style="font-size: clamp(4rem, 10vw, 150px);">
                100%</h3>
              <!-- Gold Arrow Icon -->
              <div class="w-20 h-20 lg:w-24 lg:h-24 flex items-center justify-center border border-black/10 rounded-full group-hover:border-white/20 transition-all duration-500">
                <svg
                  class="w-8 h-8 lg:w-10 lg:h-10 text-[#B89456] transition-transform duration-500 group-hover:translate-x-1 group-hover:-translate-y-1"
                  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M7 17 L17 7 M7 7 H17 V17" />
                </svg>
              </div>
            </div>
            <div class="space-y-4">
              <h4 class="text-2xl lg:text-3xl font-700 text-black group-hover:text-white transition-colors duration-500 tracking-tight"
                style="text-transform: none !important;">Indeks Kepercayaan Mitra</h4>
              <p class="text-[15px] lg:text-[16px] text-gray-500 font-500 leading-relaxed group-hover:text-white/60 transition-colors duration-500"
                style="text-transform: none !important;">
                Dedikasi berkelanjutan yang membangun fondasi kepercayaan dengan mitra strategis selama lebih dari satu dekade.
              </p>
            </div>
          </div>

          <!-- Card 2 -->
          <div
            class="bg-[#F8F8F6] border border-black/5 !p-12 md:!p-16 lg:!p-20 flex flex-col justify-between achievement-card opacity-0 translate-y-10 group rounded-none shadow-sm transition-all duration-700 hover:bg-black hover:border-black">
            <div class="flex justify-between items-start !mb-16 md:!mb-24">
              <h3 class="font-900 tracking-[-0.05em] leading-none text-black group-hover:text-white transition-colors duration-500" style="font-size: clamp(4rem, 10vw, 150px);">
                10+</h3>
              <div class="w-20 h-20 lg:w-24 lg:h-24 flex items-center justify-center border border-black/10 rounded-full group-hover:border-white/20 transition-all duration-500">
                <svg
                  class="w-8 h-8 lg:w-10 lg:h-10 text-[#B89456] transition-transform duration-500 group-hover:translate-x-1 group-hover:-translate-y-1"
                  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M7 17 L17 7 M7 7 H17 V17" />
                </svg>
              </div>
            </div>
            <div class="space-y-4">
              <h4 class="text-2xl lg:text-3xl font-700 text-black group-hover:text-white transition-colors duration-500 tracking-tight"
                style="text-transform: none !important;">Tahun Pengalaman Kerja</h4>
              <p class="text-[15px] lg:text-[16px] text-gray-500 font-500 leading-relaxed group-hover:text-white/60 transition-colors duration-500"
                style="text-transform: none !important;">
                Perjalanan panjang dalam menyatukan inovasi teknis dengan eksekusi presisi untuk hasil yang tak tertandingi.
              </p>
            </div>
          </div>

          <!-- Card 3 -->
          <div
            class="bg-[#F8F8F6] border border-black/5 !p-12 md:!p-16 lg:!p-20 flex flex-col justify-between achievement-card opacity-0 translate-y-10 group rounded-none shadow-sm transition-all duration-700 hover:bg-black hover:border-black">
            <div class="flex justify-between items-start !mb-16 md:!mb-24">
              <h3 class="font-900 tracking-[-0.05em] leading-none text-black group-hover:text-white transition-colors duration-500" style="font-size: clamp(4rem, 10vw, 150px);">
                50+</h3>
              <div class="w-20 h-20 lg:w-24 lg:h-24 flex items-center justify-center border border-black/10 rounded-full group-hover:border-white/20 transition-all duration-500">
                <svg
                  class="w-8 h-8 lg:w-10 lg:h-10 text-[#B89456] transition-transform duration-500 group-hover:translate-x-1 group-hover:-translate-y-1"
                  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M7 17 L17 7 M7 7 H17 V17" />
                </svg>
              </div>
            </div>
            <div class="space-y-4">
              <h4 class="text-2xl lg:text-3xl font-700 text-black group-hover:text-white transition-colors duration-500 tracking-tight"
                style="text-transform: none !important;">Proyek Skala Nasional</h4>
              <p class="text-[15px] lg:text-[16px] text-gray-500 font-500 leading-relaxed group-hover:text-white/60 transition-colors duration-500"
                style="text-transform: none !important;">
                Portofolio lintas daerah yang membuktikan kapasitas kepemimpinan Yotek di berbagai sektor industri strategis.
              </p>
            </div>
          </div>

        </div>
      </div>

      <!-- Right Group: Sticky Text -->
      <div class="w-full lg:w-[35%] relative">
        <div class="lg:sticky lg:top-40 !pt-4" id="achievement-text">
          <p class="achievement-txt opacity-0 text-[13px] font-800 uppercase tracking-widest text-[#B89456] !mb-6">Performance Index</p>

          <h2 class="achievement-txt opacity-0 font-700 leading-[1.1] tracking-[-0.04em] text-black !mb-8"
            style="font-size: clamp(2.5rem, 5vw, 72px); text-transform: none !important;">
            Torehan Bukti <br />
            <span class="text-gray-300">di Setiap Langkah.</span>
          </h2>

          <p class="achievement-txt opacity-0 text-[16px] lg:text-[18px] text-gray-500 font-500 leading-relaxed lg:w-[95%]"
            style="text-transform: none !important;">
            Kami tidak hanya mengejar angka, tetapi memastikan setiap langkah memberikan nilai nyata bagi seluruh mitra melalui integritas dan dedikasi tinggi.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAchievement() {
    gsap.killTweensOf(".achievement-card, .achievement-txt");

    // 1. Efek Entrance Minimalis untuk Kumpulan Kartu Kiri
    gsap.to(".achievement-card", {
      scrollTrigger: {
        trigger: "#achievement-cards",
        start: "top 80%",
      },
      y: 0,
      opacity: 1,
      boxShadow: "0 25px 50px -12px rgba(0, 0, 0, 0.08)", // Efek shadow elegan pas muncul (scroll)
      duration: 1.2,
      stagger: 0.2,
      ease: "power3.out"
    });

    // 2. Efek Entrance Sangat Elegan & Profesional untuk Teks Kanan
    gsap.fromTo(".achievement-txt",
      {
        y: 30,
        opacity: 0
      },
      {
        scrollTrigger: {
          trigger: "#achievement-text",
          start: "top 75%",
        },
        y: 0,
        opacity: 1,
        duration: 1.4,
        stagger: 0.25,
        ease: "power4.out"
      }
    );
  }

  // Gunakan astro:page-load agar bekerja mulus dengan View Transitions
  document.addEventListener('astro:page-load', initAchievement);
</script>